---
// MAIA Analytics — AI geospatial platform I'm building
// Portfolio showcase with magic card + mini map viz
---

<div class="maia-showcase" id="maia-showcase">
  <a class="maia-card" id="maia-card" href="https://maia-analytics.com" target="_blank" rel="noopener">
    <div class="maia-content">
      <div class="maia-header">
        <img src="/MAIA-logo-white.svg" alt="MAIA" class="maia-logo" />
        <span class="maia-badge">Founder</span>
      </div>
      <p class="maia-tagline">AI geospatial platform</p>
      <p class="maia-desc">Building the interface between natural language and mapping data. Ask questions, get maps — site selection, solar analysis, location intelligence.</p>

      <div class="maia-mini-map" id="maia-mini-map">
        <canvas id="maia-canvas" width="320" height="120"></canvas>
        <div class="maia-query" id="maia-query"></div>
      </div>

      <div class="maia-stack">
        <span class="maia-tech">React</span>
        <span class="maia-tech">FastAPI</span>
        <span class="maia-tech">Python</span>
        <span class="maia-tech">Postgres</span>
        <span class="maia-tech">DuckDB</span>
        <span class="maia-tech">Pydantic AI</span>
        <span class="maia-tech">GCP</span>
      </div>

      <div class="maia-footer">
        <span class="maia-link">maia-analytics.com ↗</span>
      </div>
    </div>
  </a>
</div>

<script>
  function initMaia() {
    const canvas = document.getElementById('maia-canvas') as HTMLCanvasElement;
    const queryEl = document.getElementById('maia-query');
    if (!canvas || !queryEl) return;

    // Mini map visualization — animated data points appearing
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = window.devicePixelRatio || 1;
    canvas.width = canvas.offsetWidth * dpr;
    canvas.height = canvas.offsetHeight * dpr;
    ctx.scale(dpr, dpr);
    const w = canvas.offsetWidth;
    const h = canvas.offsetHeight;

    // Generate "map" points
    const points: { x: number; y: number; r: number; born: number; color: string }[] = [];
    const colors = ['rgba(0, 220, 255, 0.6)', 'rgba(132, 204, 22, 0.5)', 'rgba(0, 180, 210, 0.4)'];

    function spawnPoint(time: number) {
      points.push({
        x: Math.random() * w,
        y: Math.random() * h,
        r: 2 + Math.random() * 4,
        born: time,
        color: colors[Math.floor(Math.random() * colors.length)],
      });
      if (points.length > 30) points.shift();
    }

    // Typewriter query animation
    const queries = [
      'show solar potential in Denver...',
      'find parcels > 2 acres near I-70...',
      'map building footprints downtown...',
      'analyze rooftop area for panels...',
    ];
    let queryIndex = 0;
    let charIndex = 0;
    let queryDir = 1;
    let queryPause = 0;

    function tickQuery() {
      if (queryPause > 0) { queryPause--; return; }
      const q = queries[queryIndex];
      if (queryDir === 1) {
        charIndex++;
        if (charIndex >= q.length) { queryDir = -1; queryPause = 40; }
      } else {
        charIndex--;
        if (charIndex <= 0) {
          queryDir = 1;
          queryIndex = (queryIndex + 1) % queries.length;
        }
      }
      queryEl.textContent = '> ' + q.slice(0, charIndex);
    }

    let lastSpawn = 0;
    let frame = 0;

    function draw(time: number) {
      ctx.clearRect(0, 0, w, h);

      // Draw grid lines
      ctx.strokeStyle = 'rgba(0, 120, 140, 0.1)';
      ctx.lineWidth = 0.5;
      for (let x = 0; x < w; x += 20) {
        ctx.beginPath();
        ctx.moveTo(x, 0);
        ctx.lineTo(x, h);
        ctx.stroke();
      }
      for (let y = 0; y < h; y += 20) {
        ctx.beginPath();
        ctx.moveTo(0, y);
        ctx.lineTo(w, y);
        ctx.stroke();
      }

      // Spawn new points
      if (time - lastSpawn > 300) {
        spawnPoint(time);
        lastSpawn = time;
      }

      // Draw points with pulse
      points.forEach(p => {
        const age = time - p.born;
        const alpha = Math.min(age / 500, 1) * (age > 4000 ? Math.max(0, 1 - (age - 4000) / 1000) : 1);
        const pulseR = p.r + Math.sin(age / 300) * 1;

        // Outer glow
        ctx.beginPath();
        ctx.arc(p.x, p.y, pulseR * 3, 0, Math.PI * 2);
        ctx.fillStyle = p.color.replace(/[\d.]+\)$/, `${alpha * 0.15})`);
        ctx.fill();

        // Inner dot
        ctx.beginPath();
        ctx.arc(p.x, p.y, pulseR, 0, Math.PI * 2);
        ctx.fillStyle = p.color.replace(/[\d.]+\)$/, `${alpha})`);
        ctx.fill();
      });

      // Query ticker
      frame++;
      if (frame % 3 === 0) tickQuery();

      requestAnimationFrame(draw);
    }

    requestAnimationFrame(draw);
  }

  initMaia();
</script>

<style>
  .maia-showcase {
    margin-bottom: 2rem;
  }

  .maia-card {
    display: block;
    position: relative;
    background: #00272b;
    border: 1px solid rgba(0, 120, 140, 0.3);
    border-radius: 12px;
    padding: 1.75rem;
    overflow: hidden;
    text-decoration: none;
    color: white;
    transition: border-color 0.3s;
  }

  .maia-card:hover {
    border-color: rgba(0, 120, 140, 0.6);
  }

  .maia-content {
    position: relative;
    z-index: 1;
  }

  .maia-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .maia-logo {
    height: 22px;
    width: auto;
  }

  .maia-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.15rem 0.5rem;
    background: rgba(0, 180, 210, 0.2);
    color: rgba(0, 220, 255, 0.8);
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .maia-tagline {
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 0.35rem;
  }

  .maia-desc {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  /* Mini map */
  .maia-mini-map {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(0, 120, 140, 0.2);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  #maia-canvas {
    display: block;
    width: 100%;
    height: 100px;
  }

  .maia-query {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: rgba(0, 220, 255, 0.6);
    padding: 0.4rem 0.6rem;
    border-top: 1px solid rgba(0, 120, 140, 0.15);
    min-height: 1.5rem;
  }

  /* Tech stack */
  .maia-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
  }

  .maia-tech {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.1rem 0.4rem;
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.4);
    border-radius: 3px;
  }

  .maia-footer {
    display: flex;
    justify-content: flex-end;
  }

  .maia-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: rgba(0, 220, 255, 0.5);
    transition: color 0.2s;
  }

  .maia-card:hover .maia-link {
    color: rgba(0, 220, 255, 0.9);
  }
</style>
