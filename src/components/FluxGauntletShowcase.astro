---
// Flux Gauntlet — wearable LED controller with per-finger buttons
// Interactive showcase with animated LED strip and effect switching
---

<div class="fg-showcase">
  <a class="fg-card" href="https://github.com/c2keesey/Flux-Gauntlet" target="_blank" rel="noopener">
    <div class="fg-glow"></div>
    <div class="fg-content">
      <div class="fg-header">
        <span class="fg-name text-scramble" data-text="Flux Gauntlet" data-delay="100" data-always="false">Flux Gauntlet</span>
        <span class="fg-badge">wearable</span>
      </div>
      <p class="fg-tagline">Wearable LED instrument</p>
      <p class="fg-desc">Custom gauntlet with 300 WS2812 LEDs, 5 per-finger buttons, rotary encoder, and OLED display. 15+ effects — blasts, fire rings, lightning, collisions — all switchable in real time.</p>

      <div class="fg-media">
        <img src="/flux-gauntlet.gif" alt="Flux Gauntlet in action" class="fg-photo" onerror="this.parentElement.style.display='none'" />
      </div>

      <div class="fg-viz">
        <canvas id="fg-canvas"></canvas>
        <div class="fg-controls">
          <button class="fg-btn" data-effect="blast" title="Ring-by-ring expanding pulse">blast</button>
          <button class="fg-btn" data-effect="lightning" title="Jagged bolt with flash">lightning</button>
          <button class="fg-btn" data-effect="fire" title="Heat simulation">fire</button>
          <button class="fg-btn" data-effect="firework" title="Particle explosion">firework</button>
          <button class="fg-btn" data-effect="casimir" title="Ring segments paint & erase">casimir</button>
          <button class="fg-btn" data-effect="twinkle" title="Fading stars">twinkle</button>
          <button class="fg-btn" data-effect="pew" title="Projectile shot">pew</button>
        </div>
      </div>

      <div class="fg-specs">
        <div class="fg-spec">
          <span class="fg-spec-val">300</span>
          <span class="fg-spec-label">LEDs</span>
        </div>
        <div class="fg-spec-sep"></div>
        <div class="fg-spec">
          <span class="fg-spec-val">5</span>
          <span class="fg-spec-label">buttons</span>
        </div>
        <div class="fg-spec-sep"></div>
        <div class="fg-spec">
          <span class="fg-spec-val">15+</span>
          <span class="fg-spec-label">effects</span>
        </div>
        <div class="fg-spec-sep"></div>
        <div class="fg-spec">
          <span class="fg-spec-val">ESP32</span>
          <span class="fg-spec-label">brain</span>
        </div>
      </div>

      <div class="fg-stack">
        <span class="fg-tech">C++</span>
        <span class="fg-tech">PlatformIO</span>
        <span class="fg-tech">FastLED</span>
        <span class="fg-tech">ESP32</span>
        <span class="fg-tech">U8g2</span>
        <span class="fg-tech">WS2812</span>
      </div>

      <div class="fg-footer">
        <span class="fg-pre-llm">hand-written · 2024 · pre-LLM</span>
        <span class="fg-link">github.com/c2keesey/Flux-Gauntlet ↗</span>
      </div>
    </div>
  </a>
</div>

<script>
  function initFluxGauntlet() {
    const canvas = document.getElementById('fg-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = window.devicePixelRatio || 1;
    const w = canvas.offsetWidth;
    const h = canvas.offsetHeight;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    ctx.scale(dpr, dpr);

    // Real ring layout: 16 rings, wrist (21) to fingertip (10), total 300
    const ringSizes = [21, 27, 25, 23, 23, 22, 20, 19, 19, 19, 17, 16, 15, 12, 12, 10];
    const numRings = ringSizes.length;
    const numLeds = ringSizes.reduce((a, b) => a + b, 0); // 300
    // Precompute ring start indices
    const ringStart: number[] = [];
    let acc = 0;
    for (const s of ringSizes) { ringStart.push(acc); acc += s; }

    let leds: { r: number; g: number; b: number }[] = Array.from({ length: numLeds }, () => ({ r: 0, g: 0, b: 0 }));
    let effect = 'blast';
    let time = 0;

    // Spiral arm geometry — 300 LEDs wrapping around a cylinder
    const cy = h / 2;
    const armRadiusY = h * 0.32;
    const armLeft = w * 0.10;
    const armRight = w * 0.90;
    const armLen = armRight - armLeft;

    interface LedPos { x: number; y: number; z: number; ring: number; }
    const ledPositions: LedPos[] = [];

    // Place LEDs ring by ring, each ring wraps around the arm at its x position
    for (let ring = 0; ring < numRings; ring++) {
      const ringX = armLeft + (ring / (numRings - 1)) * armLen;
      const size = ringSizes[ring];
      for (let j = 0; j < size; j++) {
        const angle = (j / size) * Math.PI * 2;
        const yOff = Math.sin(angle) * armRadiusY;
        const zVal = Math.cos(angle);
        ledPositions.push({ x: ringX, y: cy + yOff, z: zVal, ring });
      }
    }

    // Color helpers
    let hueCounter = 0;
    function nextHue() { hueCounter = (hueCounter + 37) % 360; return hueCounter; }

    function hsvToRgb(h: number, s: number, v: number) {
      h = ((h % 360) + 360) % 360;
      s = Math.min(1, Math.max(0, s));
      v = Math.min(1, Math.max(0, v));
      const c = v * s, x = c * (1 - Math.abs((h / 60) % 2 - 1)), m = v - c;
      let r = 0, g = 0, b = 0;
      if (h < 60) { r = c; g = x; }
      else if (h < 120) { r = x; g = c; }
      else if (h < 180) { g = c; b = x; }
      else if (h < 240) { g = x; b = c; }
      else if (h < 300) { r = x; b = c; }
      else { r = c; b = x; }
      return { r: Math.round((r + m) * 255), g: Math.round((g + m) * 255), b: Math.round((b + m) * 255) };
    }

    function heatColor(heat: number) {
      // Mimic FastLED HeatColor: black → red → orange → yellow → white
      const t = Math.min(1, Math.max(0, heat));
      if (t < 0.33) { const s = t / 0.33; return { r: Math.round(s * 255), g: 0, b: 0 }; }
      if (t < 0.66) { const s = (t - 0.33) / 0.33; return { r: 255, g: Math.round(s * 180), b: 0 }; }
      const s = (t - 0.66) / 0.34;
      return { r: 255, g: 180 + Math.round(s * 75), b: Math.round(s * 140) };
    }

    function setLed(i: number, r: number, g: number, b: number) {
      if (i >= 0 && i < numLeds) {
        leds[i].r = Math.min(255, Math.max(0, r));
        leds[i].g = Math.min(255, Math.max(0, g));
        leds[i].b = Math.min(255, Math.max(0, b));
      }
    }

    function addLed(i: number, r: number, g: number, b: number) {
      if (i >= 0 && i < numLeds) {
        leds[i].r = Math.min(255, leds[i].r + r);
        leds[i].g = Math.min(255, leds[i].g + g);
        leds[i].b = Math.min(255, leds[i].b + b);
      }
    }

    function clear() { for (let i = 0; i < numLeds; i++) leds[i] = { r: 0, g: 0, b: 0 }; }
    function fade(amount: number) {
      for (let i = 0; i < numLeds; i++) {
        leds[i].r = Math.max(0, leds[i].r - amount);
        leds[i].g = Math.max(0, leds[i].g - amount);
        leds[i].b = Math.max(0, leds[i].b - amount);
      }
    }

    // Fill an entire ring with a color
    function fillRing(ring: number, r: number, g: number, b: number) {
      if (ring < 0 || ring >= numRings) return;
      const start = ringStart[ring];
      for (let j = 0; j < ringSizes[ring]; j++) setLed(start + j, r, g, b);
    }

    // === BLAST: ring-by-ring expanding pulse from wrist to fingertip ===
    interface BlastRing { ring: number; hue: number; }
    let blastRings: BlastRing[] = [];
    function tickBlast() {
      fade(18);
      if (time % 8 === 0) {
        blastRings.push({ ring: 0, hue: nextHue() });
      }
      for (let i = blastRings.length - 1; i >= 0; i--) {
        const b = blastRings[i];
        if (b.ring < numRings) {
          const c = hsvToRgb(b.hue, 1, 1);
          fillRing(b.ring, c.r, c.g, c.b);
          b.ring++;
        } else {
          blastRings.splice(i, 1);
        }
      }
    }

    // === LIGHTNING: jagged bolt grows, flashes, dissipates ===
    interface Bolt { path: number[]; state: 'grow' | 'flash' | 'fade'; step: number; hue: number; brightness: number; flashCount: number; }
    let bolts: Bolt[] = [];
    function tickLightning() {
      fade(12);
      // Spawn new bolt periodically
      if (time % 40 === 0) {
        const startLed = ringStart[0] + Math.floor(Math.random() * ringSizes[0]);
        bolts.push({ path: [startLed], state: 'grow', step: 0, hue: nextHue(), brightness: 255, flashCount: 0 });
      }
      for (let i = bolts.length - 1; i >= 0; i--) {
        const bolt = bolts[i];
        if (bolt.state === 'grow') {
          // Grow one ring per tick
          const currentRing = bolt.path.length - 1;
          if (currentRing < numRings - 1) {
            const nextRing = currentRing + 1;
            const basePos = ringStart[nextRing];
            const jitter = Math.floor(Math.random() * 5) - 2;
            const nextLed = basePos + Math.max(0, Math.min(ringSizes[nextRing] - 1,
              Math.floor(ringSizes[nextRing] / 2) + jitter));
            bolt.path.push(nextLed);
          } else {
            bolt.state = 'flash'; bolt.step = 0;
          }
        } else if (bolt.state === 'flash') {
          bolt.step++;
          bolt.brightness = bolt.step % 2 === 0 ? 255 : 60;
          if (bolt.step >= 8) { bolt.state = 'fade'; bolt.brightness = 255; }
        } else {
          bolt.brightness -= 15;
          if (bolt.brightness <= 0) { bolts.splice(i, 1); continue; }
        }
        // Draw bolt path
        const c = hsvToRgb(bolt.hue, 0.3, bolt.brightness / 255);
        for (const led of bolt.path) {
          setLed(led, c.r, c.g, c.b);
          // Light neighbors for thickness
          if (led > 0) addLed(led - 1, c.r >> 2, c.g >> 2, c.b >> 2);
          if (led < numLeds - 1) addLed(led + 1, c.r >> 2, c.g >> 2, c.b >> 2);
        }
      }
    }

    // === FIRE: heat diffusion simulation ===
    const heatMap: number[] = new Array(numLeds).fill(0);
    function tickFire() {
      // Cool
      for (let i = 0; i < numLeds; i++) {
        heatMap[i] = Math.max(0, heatMap[i] - Math.random() * 0.012);
      }
      // Diffuse
      const prev = [...heatMap];
      for (let i = 2; i < numLeds - 2; i++) {
        heatMap[i] = (prev[i] * 4 + prev[i - 1] * 5 + prev[i + 1] * 4 + prev[i - 2] * 3 + prev[i + 2] * 2) / 18;
      }
      // Spark near fingertip end (reversed like the real effect)
      for (let ring = numRings - 3; ring < numRings; ring++) {
        const start = ringStart[ring];
        for (let j = 0; j < ringSizes[ring]; j++) {
          if (Math.random() < 0.03) {
            heatMap[start + j] = Math.min(1, heatMap[start + j] + 0.5 + Math.random() * 0.5);
          }
        }
      }
      // Periodic burst (simulates button press)
      if (time % 60 === 0) {
        for (let k = 0; k < 10; k++) {
          const ring = numRings - 1 - Math.floor(Math.random() * 3);
          const idx = ringStart[ring] + Math.floor(Math.random() * ringSizes[ring]);
          heatMap[idx] = 0.7 + Math.random() * 0.3;
        }
      }
      // Render
      for (let i = 0; i < numLeds; i++) {
        const c = heatColor(heatMap[i]);
        leds[i] = c;
      }
    }

    // === FIREWORK: particle explosion ===
    interface FwParticle { pos: number; vel: number; hue: number; brightness: number; }
    let fwParticles: FwParticle[] = [];
    function tickFirework() {
      fade(6);
      // Auto-spawn fireworks
      if (time % 35 === 0) {
        const center = 50 + Math.floor(Math.random() * (numLeds - 100));
        const hue = nextHue();
        const count = 20 + Math.floor(Math.random() * 30);
        for (let k = 0; k < count; k++) {
          const speed = (Math.random() < 0.5 ? -1 : 1) * (2 + Math.random() * 8);
          fwParticles.push({ pos: center, vel: speed, hue: hue + Math.random() * 30, brightness: 255 });
        }
      }
      for (let i = fwParticles.length - 1; i >= 0; i--) {
        const p = fwParticles[i];
        p.pos += p.vel * 0.15;
        p.vel *= 0.97; // deceleration
        // Fade faster when slow
        const fadeRate = Math.abs(p.vel) < 1 ? 8 : 3;
        p.brightness -= fadeRate;
        if (p.brightness <= 0 || p.pos < 0 || p.pos >= numLeds) {
          fwParticles.splice(i, 1); continue;
        }
        const idx = Math.round(p.pos);
        const v = p.brightness / 255;
        const c = hsvToRgb(p.hue, 1, v);
        addLed(idx, c.r, c.g, c.b);
      }
    }

    // === CASIMIR: ring segments that paint in then erase ===
    interface CasimirSeg { start: number; len: number; step: number; erasing: boolean; hue: number; }
    let casimirSegs: CasimirSeg[] = [];
    function tickCasimir() {
      fade(4);
      // Spawn new segments
      if (time % 6 === 0) {
        const ring = Math.floor(Math.random() * numRings);
        casimirSegs.push({
          start: ringStart[ring], len: ringSizes[ring],
          step: 0, erasing: false, hue: nextHue()
        });
      }
      for (let i = casimirSegs.length - 1; i >= 0; i--) {
        const seg = casimirSegs[i];
        if (!seg.erasing) {
          // Paint LED by LED
          if (seg.step < seg.len) {
            const c = hsvToRgb(seg.hue + seg.step * 8, 1, 1);
            setLed(seg.start + seg.step, c.r, c.g, c.b);
            seg.step++;
          } else {
            seg.erasing = true; seg.step = 0;
          }
        } else {
          // Erase LED by LED
          if (seg.step < seg.len) {
            setLed(seg.start + seg.step, 0, 0, 0);
            seg.step++;
          } else {
            casimirSegs.splice(i, 1);
          }
        }
      }
    }

    // === TWINKLE: stars that fade in/out with drift ===
    interface Star { pos: number; hue: number; val: number; fadeSpeed: number; fadingIn: boolean; drift: number; }
    let stars: Star[] = [];
    function tickTwinkle() {
      // Dim background
      for (let i = 0; i < numLeds; i++) {
        leds[i].r = Math.max(0, leds[i].r - 2);
        leds[i].g = Math.max(0, leds[i].g - 2);
        leds[i].b = Math.max(0, leds[i].b - 2);
      }
      // Spawn new stars
      if (time % 2 === 0 && stars.length < 60) {
        stars.push({
          pos: Math.random() * numLeds,
          hue: Math.random() < 0.5 ? 0 + Math.random() * 30 : 200 + Math.random() * 160,
          val: 0, fadeSpeed: 1 + Math.random() * 4, fadingIn: true,
          drift: (Math.random() - 0.5) * 0.06,
        });
      }
      for (let i = stars.length - 1; i >= 0; i--) {
        const s = stars[i];
        s.pos += s.drift;
        if (s.fadingIn) {
          s.val = Math.min(255, s.val + s.fadeSpeed * 2);
          if (s.val >= 255) s.fadingIn = false;
        } else {
          s.val -= s.fadeSpeed;
          if (s.val <= 0) { stars.splice(i, 1); continue; }
        }
        const idx = Math.round(s.pos);
        const v = s.val / 255;
        const c = hsvToRgb(s.hue, 0.85, v);
        addLed(idx, c.r, c.g, c.b);
      }
    }

    // === PEW: projectile shot from fingertip to wrist ===
    interface Beam { pos: number; hue: number; }
    let beams: Beam[] = [];
    function tickPew() {
      fade(25);
      if (time % 20 === 0) {
        beams.push({ pos: numLeds - 1, hue: 270 + Math.random() * 60 });
      }
      for (let i = beams.length - 1; i >= 0; i--) {
        const b = beams[i];
        b.pos -= 2.5;
        if (b.pos < -5) { beams.splice(i, 1); continue; }
        const c = hsvToRgb(b.hue, 1, 1);
        // 4-LED projectile with trail
        for (let j = 0; j < 5; j++) {
          const idx = Math.round(b.pos + j);
          const trail = 1 - j * 0.2;
          if (idx >= 0 && idx < numLeds) {
            setLed(idx, c.r * trail, c.g * trail, c.b * trail);
          }
        }
      }
    }

    const effects: Record<string, () => void> = {
      blast: tickBlast, lightning: tickLightning, fire: tickFire,
      firework: tickFirework, casimir: tickCasimir, twinkle: tickTwinkle, pew: tickPew,
    };

    function resetState() {
      blastRings = []; bolts = []; fwParticles = []; casimirSegs = []; stars = []; beams = [];
      heatMap.fill(0);
      clear();
      time = 0;
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);
      effects[effect]?.();
      time++;

      // Sort LEDs by z so back ones draw first (painter's algorithm)
      const indices = Array.from({ length: numLeds }, (_, i) => i);
      indices.sort((a, b) => ledPositions[a].z - ledPositions[b].z);

      for (const idx of indices) {
        const pos = ledPositions[idx];
        const { r, g, b } = leds[idx];
        const brightness = (r + g + b) / 3;

        const depthScale = 0.5 + (pos.z + 1) / 2 * 0.5;
        const depthAlpha = 0.3 + (pos.z + 1) / 2 * 0.7;
        const ledR = 2 * depthScale;

        if (brightness > 5) {
          const glowR = ledR * (3 + depthScale * 2);
          const grd = ctx.createRadialGradient(pos.x, pos.y, 0, pos.x, pos.y, glowR);
          grd.addColorStop(0, `rgba(${r}, ${g}, ${b}, ${0.35 * depthAlpha})`);
          grd.addColorStop(1, 'transparent');
          ctx.fillStyle = grd;
          ctx.fillRect(pos.x - glowR, pos.y - glowR, glowR * 2, glowR * 2);
        }

        ctx.beginPath();
        ctx.arc(pos.x, pos.y, ledR, 0, Math.PI * 2);
        ctx.fillStyle = brightness > 5
          ? `rgba(${r}, ${g}, ${b}, ${depthAlpha})`
          : `rgba(255, 255, 255, ${0.04 * depthAlpha})`;
        ctx.fill();
      }

      requestAnimationFrame(draw);
    }

    // Button handlers
    document.querySelectorAll<HTMLButtonElement>('.fg-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const fx = btn.dataset.effect;
        if (fx) {
          effect = fx;
          resetState();
          document.querySelectorAll('.fg-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
        }
      });
    });

    document.querySelector('.fg-btn[data-effect="blast"]')?.classList.add('active');
    requestAnimationFrame(draw);
  }

  initFluxGauntlet();
</script>

<style>
  .fg-showcase {
    margin-bottom: 2rem;
  }

  .fg-card {
    display: block;
    position: relative;
    background: linear-gradient(145deg, rgba(255, 60, 20, 0.05), rgba(180, 40, 255, 0.04), rgba(20, 20, 30, 0.95));
    border: 1px solid rgba(255, 100, 50, 0.2);
    border-radius: 12px;
    padding: 1.75rem;
    overflow: hidden;
    text-decoration: none;
    color: white;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .fg-card:hover {
    border-color: rgba(255, 100, 50, 0.5);
    box-shadow: 0 0 30px rgba(255, 60, 20, 0.08), 0 0 60px rgba(180, 40, 255, 0.04);
  }

  .fg-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(ellipse at 30% 20%, rgba(255, 80, 30, 0.06) 0%, transparent 50%),
                radial-gradient(ellipse at 70% 80%, rgba(140, 50, 255, 0.04) 0%, transparent 50%);
    pointer-events: none;
    animation: fg-glow-shift 8s ease-in-out infinite alternate;
  }

  @keyframes fg-glow-shift {
    0% { transform: translate(0, 0); }
    100% { transform: translate(5%, -5%); }
  }

  .fg-content {
    position: relative;
    z-index: 1;
  }

  .fg-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .fg-name {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    font-weight: 700;
    background: linear-gradient(135deg, #ff6b35, #c850c0, #6a5aff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .fg-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.15rem 0.5rem;
    background: rgba(255, 100, 50, 0.15);
    color: rgba(255, 130, 70, 0.9);
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .fg-tagline {
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 0.35rem;
  }

  .fg-desc {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  /* Photo/GIF */
  .fg-media {
    margin-bottom: 0.75rem;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(255, 100, 50, 0.15);
  }

  .fg-photo {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    max-height: 200px;
  }

  /* LED visualization */
  .fg-viz {
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 100, 50, 0.15);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  #fg-canvas {
    display: block;
    width: 100%;
    height: 120px;
  }

  .fg-controls {
    display: flex;
    gap: 0;
    border-top: 1px solid rgba(255, 100, 50, 0.1);
  }

  .fg-btn {
    flex: 1;
    padding: 0.4rem;
    background: none;
    border: none;
    border-right: 1px solid rgba(255, 100, 50, 0.1);
    color: rgba(255, 255, 255, 0.3);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .fg-btn:last-child {
    border-right: none;
  }

  .fg-btn:hover {
    background: rgba(255, 100, 50, 0.08);
    color: rgba(255, 255, 255, 0.6);
  }

