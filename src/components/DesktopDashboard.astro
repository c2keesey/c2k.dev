---
// Desktop dashboard: network graph of projects with meaningful labeled connections
// Only visible at >=1024px; mobile keeps the stacked showcase view

interface Project {
  id: string;
  name: string;
  tagline: string;
  description: string;
  badge: string;
  status: 'ONLINE' | 'DEPLOYING' | 'STANDBY';
  pulseRate: number;
  wip?: boolean;
  tech: string[];
  link?: string;
  linkText?: string;
  color: string;
  hero?: 'maia' | 'flux' | 'c2k';
  x: number;
  y: number;
}

interface Edge {
  from: string;
  to: string;
  label: string;
  color: string;
}

