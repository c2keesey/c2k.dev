---
// Desktop dashboard: network graph of projects with meaningful labeled connections
// Only visible at >=1024px; mobile keeps the stacked showcase view

interface Project {
  id: string;
  name: string;
  tagline: string;
  description: string;
  badge: string;
  status: 'ONLINE' | 'DEPLOYING' | 'STANDBY';
  pulseRate: number;
  wip?: boolean;
  tech: string[];
  link?: string;
  linkText?: string;
  color: string;
  x: number;
  y: number;
}

interface Edge {
  from: string;
  to: string;
  label: string;
  color: string;
}

const projects: Project[] = [
  {
    id: 'maia', name: 'MAIA', tagline: 'AI geospatial platform',
    description: 'Full-stack AI-native geospatial platform. Ask questions, get maps. LLM orchestration, agentic workflows, property data pipelines.',
    badge: 'startup', status: 'ONLINE', pulseRate: 2,
    tech: ['TypeScript', 'Python', 'FastAPI', 'Postgres', 'GCP'],
    link: 'https://maia-analytics.com', linkText: 'maia-analytics.com',
    color: '6, 182, 212', x: 14, y: 16,
  },
  {
    id: 'c2k', name: 'c2k.page', tagline: 'This website',
    description: 'Personal site as system monitor. Self-hosted Astro SSR on an OptiPlex micro, exposed via Cloudflare Tunnel. Hand-crafted interactive showcases.',
    badge: 'web', status: 'ONLINE', pulseRate: 2.5,
    tech: ['Astro', 'TypeScript', 'Canvas', 'Cloudflare'],
    link: 'https://c2k.page', linkText: 'c2k.page',
    color: '168, 85, 247', x: 22, y: 42,
  },
  {
    id: 'dotfiles', name: 'Dotfiles', tagline: 'Dev environment system',
    description: 'Version-controlled dev environment. Shell, editor, keybindings, Claude Code skills and hooks — all symlinked and synced across machines.',
    badge: 'tooling', status: 'ONLINE', pulseRate: 3.5,
    tech: ['Bash', 'Zsh', 'Claude Code', 'Tmux', 'Ghostty'],
    link: 'https://github.com/c2keesey/dotfiles', linkText: 'github/dotfiles',
    color: '168, 85, 247', x: 48, y: 14,
  },
  {
    id: 'spotify', name: 'Spotify Macro', tagline: 'Stream Deck automations',
    description: 'Five Spotify automations for Stream Deck. Playlist sorting, genre classification, heart sync, hotkey control, queue management.',
    badge: 'automation', status: 'ONLINE', pulseRate: 4,
    tech: ['Python', 'Spotify API', 'Stream Deck SDK'],
    link: 'https://github.com/c2keesey/spotify-macro-pad', linkText: 'github/spotify-macro',
    color: '34, 197, 94', x: 8, y: 68,
  },
  {
    id: 'secretgate', name: 'Secret Gate', tagline: 'Human-in-the-loop gate',
    description: 'Routes AI agent requests for secrets (1Password) and sudo commands through Telegram for explicit approval. Claude Code plugin with PreToolUse hooks.',
    badge: 'security', status: 'DEPLOYING', pulseRate: 1.5, wip: true,
    tech: ['Python', '1Password CLI', 'Telegram', 'Claude Code'],
    link: 'https://github.com/c2keesey/secret-gate', linkText: 'github/secret-gate',
    color: '239, 68, 68', x: 78, y: 18,
  },
  {
    id: 'flux', name: 'Flux Gauntlet', tagline: 'LED wearable',
    description: '300-LED arm gauntlet with 16 rings on a 3D cylindrical mesh. 7 procedural effects: blast, lightning, fire, firework, casimir, twinkle, pew.',
    badge: 'hardware', status: 'STANDBY', pulseRate: 7,
    tech: ['C++', 'FastLED', 'ESP32'],
    color: '249, 115, 22', x: 38, y: 80,
  },
  {
    id: 'corne', name: 'Corne', tagline: '42-key split keyboard',
    description: 'Custom split ergonomic keyboard. 7 layers with combos, home row mods, and vim-style navigation. Fully programmable firmware.',
    badge: 'hardware', status: 'ONLINE', pulseRate: 4,
    tech: ['QMK', 'C', 'KiCad'],
    color: '139, 92, 246', x: 54, y: 52,
  },
  {
    id: 'lightning', name: 'Lightning Cloud', tagline: 'Procedural lightning',
    description: 'LED cloud lamp with procedural lightning bolt generation. Branching algorithms, flashing, fading — all code-driven on an ESP32.',
    badge: 'hardware', status: 'STANDBY', pulseRate: 8,
    tech: ['C++', 'FastLED', 'ESP32'],
    color: '59, 130, 246', x: 72, y: 70,
  },
  {
    id: 'propeller', name: 'Propeller Scrape', tagline: 'Concert ticket monitor',
    description: 'Scrapes Propeller rewards for new concert tickets in LA, SF, and Boulder. Sends Telegram notifications. Runs on cron.',
    badge: 'utility', status: 'ONLINE', pulseRate: 5,
    tech: ['Python', 'BeautifulSoup', 'Telegram', 'cron'],
    link: 'https://github.com/c2keesey/propeller-scrape', linkText: 'github/propeller-scrape',
    color: '249, 115, 22', x: 88, y: 46,
  },
];

// Real, meaningful connections between projects
const edges: Edge[] = [
  // MAIA connections
  { from: 'maia', to: 'dotfiles', label: 'primary workspace', color: '#06b6d4' },
  // c2k connections
  { from: 'c2k', to: 'dotfiles', label: 'co-hosted on optiplex', color: '#a855f7' },
  { from: 'c2k', to: 'corne', label: 'interactive keymap', color: '#8b5cf6' },
  // Dotfiles connections
  { from: 'dotfiles', to: 'corne', label: 'keyboard config', color: '#8b5cf6' },
  { from: 'dotfiles', to: 'secretgate', label: 'claude code plugin', color: '#ef4444' },
  { from: 'dotfiles', to: 'propeller', label: 'cron on optiplex', color: '#f97316' },
  // Hardware cluster
  { from: 'corne', to: 'flux', label: 'hand-soldered', color: '#f97316' },
  { from: 'corne', to: 'lightning', label: 'hand-soldered', color: '#3b82f6' },
  { from: 'flux', to: 'lightning', label: 'ESP32 + FastLED', color: '#f97316' },
  // Automation cluster
  { from: 'spotify', to: 'propeller', label: 'background automation', color: '#22c55e' },
  { from: 'secretgate', to: 'propeller', label: 'telegram bots', color: '#f97316' },
];

// Compute nominal status
const nominalCount = projects.filter(p => p.status === 'ONLINE').length;
const totalCount = projects.length;
const statusText = nominalCount === totalCount
  ? `${totalCount} SYSTEMS NOMINAL`
  : `${nominalCount}/${totalCount} NOMINAL`;

function getNode(id: string) {
  return projects.find(p => p.id === id)!;
}

// Build adjacency map: node ID -> list of edge indices
const nodeEdgeMap: Record<string, number[]> = {};
projects.forEach(p => { nodeEdgeMap[p.id] = []; });
edges.forEach((edge, i) => {
  nodeEdgeMap[edge.from]?.push(i);
  nodeEdgeMap[edge.to]?.push(i);
});

// Compute edge midpoints for labels (as percentages)
const edgeMidpoints = edges.map(edge => {
  const a = getNode(edge.from);
  const b = getNode(edge.to);
  return { x: (a.x + b.x) / 2, y: (a.y + b.y) / 2 };
});
---

<div class="dashboard" data-node-edges={JSON.stringify(nodeEdgeMap)}>
  <!-- Vignette -->
  <div class="dashboard-vignette"></div>

  <!-- Grid with breathing -->
  <div class="dashboard-grid">
    <div class="grid-breathe"></div>
  </div>

  <!-- Header -->
  <div class="dashboard-header">
    <span class="dashboard-label">PROJECT NETWORK</span>
    <span class="dashboard-status">{statusText}</span>
    <span class="dashboard-sync" id="dashboard-sync">SYNC —</span>
  </div>

  <!-- SVG edge layer -->
  <svg class="dashboard-svg" viewBox="0 0 100 100" preserveAspectRatio="none">
    {edges.map((edge, i) => {
      const a = getNode(edge.from);
      const b = getNode(edge.to);
      return (
        <line
          x1={a.x} y1={a.y} x2={b.x} y2={b.y}
          stroke={edge.color}
          stroke-width="1.5"
          opacity="0.15"
          vector-effect="non-scaling-stroke"
          stroke-linecap="round"
          class="edge-line"
          data-edge-index={String(i)}
        />
      );
    })}
  </svg>

  <!-- Edge labels (HTML for no distortion) -->
  {edges.map((edge, i) => (
    <div
      class="edge-label"
      style={`left: ${edgeMidpoints[i].x}%; top: ${edgeMidpoints[i].y}%; --edge-color: ${edge.color};`}
      data-edge-index={String(i)}
    >
      {edge.label}
    </div>
  ))}

  <!-- Project nodes -->
  {projects.map((p, i) => (
    <div
      class="dashboard-node"
      style={`left: ${p.x}%; top: ${p.y}%; --node-color: ${p.color}; --node-delay: ${i * 80}ms; --pulse-rate: ${p.pulseRate}s;`}
      data-project={p.id}
      data-edges={JSON.stringify(nodeEdgeMap[p.id])}
    >
      <div class="node-compact">
        <div class="node-top-row">
          <span class="node-status-dot" data-status={p.status}></span>
          <span class="node-name text-scramble" data-text={p.name} data-delay={String(200 + i * 60)} data-always="false">{p.name}</span>
          <span class={`node-status-label ${p.status.toLowerCase()}`}>{p.status}</span>
        </div>
        <span class="node-tagline">{p.tagline}</span>
      </div>

      <div class="node-detail">
        <div class="node-detail-badges">
          <span class="node-badge" style={`background: rgba(${p.color}, 0.1); color: rgba(${p.color}, 0.7);`}>{p.badge}</span>
          {p.wip && <span class="node-badge node-badge-wip">WIP</span>}
        </div>
        <p class="node-desc">{p.description}</p>
        <div class="node-tech">
          {p.tech.map(t => <span class="node-tech-pill">{t}</span>)}
        </div>
        {p.link && (
          <a class="node-link" href={p.link} target="_blank" rel="noopener" style={`color: rgba(${p.color}, 0.5);`}>
            {p.linkText || p.link.replace('https://', '')} ↗
          </a>
        )}
      </div>
    </div>
  ))}
</div>

<script>
  function initDashboard() {
    const dashboard = document.querySelector('.dashboard') as HTMLElement;
    if (!dashboard) return;

    const nodes = dashboard.querySelectorAll<HTMLElement>('.dashboard-node');
    const edgeLines = dashboard.querySelectorAll<SVGLineElement>('.edge-line');
    const edgeLabels = dashboard.querySelectorAll<HTMLElement>('.edge-label');
    const nodeEdgeMap: Record<string, number[]> = JSON.parse(dashboard.dataset.nodeEdges || '{}');

    let expandedNode: HTMLElement | null = null;

    function highlightNode(node: HTMLElement) {
      const projectId = node.dataset.project || '';
      const connectedEdges = new Set(nodeEdgeMap[projectId] || []);

      // Find all nodes connected to this one via edges
      const connectedNodes = new Set<string>();
      connectedNodes.add(projectId);
      edgeLines.forEach((line, i) => {
        if (connectedEdges.has(i)) {
          // Find the other node in this edge
          const edgeData = line.dataset.edgeIndex;
          // We need to find connected node IDs from the edge map
        }
      });

      // Build connected node set from edges
      nodes.forEach(other => {
        const otherId = other.dataset.project || '';
        const otherEdges = new Set(nodeEdgeMap[otherId] || []);
        const shares = [...connectedEdges].some(e => otherEdges.has(e));
        if (shares) connectedNodes.add(otherId);
      });

      // Highlight connected edges, dim others
      edgeLines.forEach((line, i) => {
        if (connectedEdges.has(i)) {
          line.classList.add('highlighted');
          line.classList.remove('dimmed');
        } else {
          line.classList.add('dimmed');
          line.classList.remove('highlighted');
        }
      });

      // Show connected edge labels
      edgeLabels.forEach((label, i) => {
        if (connectedEdges.has(i)) {
          label.classList.add('visible');
        } else {
          label.classList.remove('visible');
        }
      });

      // Dim unconnected nodes
      nodes.forEach(other => {
        const otherId = other.dataset.project || '';
        if (connectedNodes.has(otherId)) {
          other.classList.remove('dimmed');
        } else {
          other.classList.add('dimmed');
        }
      });

      dashboard.classList.add('has-focus');
    }

    function clearHighlights() {
      dashboard.classList.remove('has-focus');
      edgeLines.forEach(l => { l.classList.remove('highlighted', 'dimmed'); });
      edgeLabels.forEach(l => { l.classList.remove('visible'); });
      nodes.forEach(n => { n.classList.remove('dimmed'); });
    }

    // Hover: highlight connections
    nodes.forEach(node => {
      node.addEventListener('mouseenter', () => {
        if (expandedNode) return;
        highlightNode(node);
      });
      node.addEventListener('mouseleave', () => {
        if (expandedNode) return;
        clearHighlights();
      });
    });

    // Click: expand inline + lock highlights
    nodes.forEach(node => {
      node.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.node-link')) return;

        if (expandedNode === node) {
          expandedNode.classList.remove('expanded');
          expandedNode = null;
          clearHighlights();
          return;
        }

        if (expandedNode) {
          expandedNode.classList.remove('expanded');
        }

        expandedNode = node;
        node.classList.add('expanded');
        highlightNode(node);
      });
    });

    // Click outside to collapse
    dashboard.addEventListener('click', (e) => {
      if (expandedNode && !(e.target as HTMLElement).closest('.dashboard-node')) {
        expandedNode.classList.remove('expanded');
        expandedNode = null;
        clearHighlights();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && expandedNode) {
        expandedNode.classList.remove('expanded');
        expandedNode = null;
        clearHighlights();
      }
    });

    // Live sync counter
    const syncEl = document.getElementById('dashboard-sync');
    let lastSync = Date.now();

    async function fetchStatus() {
      try {
        const res = await fetch('/api/status');
        if (res.ok) lastSync = Date.now();
      } catch {}
      updateSync();
    }

    function updateSync() {
      if (!syncEl) return;
      const s = Math.floor((Date.now() - lastSync) / 1000);
      syncEl.textContent = s < 5 ? 'SYNC NOW' : s < 60 ? `SYNC ${s}s` : `SYNC ${Math.floor(s / 60)}m`;
    }

    fetchStatus();
    setInterval(fetchStatus, 30000);
    setInterval(updateSync, 5000);
  }

  initDashboard();
</script>

<style>
  .dashboard {
    display: none;
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .dashboard { display: block; }
  }

  /* ── Vignette ── */
  .dashboard-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 70% at 48% 45%,
      transparent 0%,
      rgba(5, 5, 7, 0.15) 60%,
      rgba(5, 5, 7, 0.45) 100%
    );
    pointer-events: none;
    z-index: 10;
  }

  /* ── Grid ── */
  .dashboard-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }

  .grid-breathe {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle 250px, rgba(168, 85, 247, 0.02), transparent);
    animation: grid-sweep 12s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes grid-sweep {
    0%   { transform: translate(-20%, -20%); }
    33%  { transform: translate(20%, -10%); }
    66%  { transform: translate(5%, 20%); }
    100% { transform: translate(-20%, -20%); }
  }

  /* ── Header ── */
  .dashboard-header {
    position: absolute;
    top: 1rem;
    left: 2rem;
    z-index: 12;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .dashboard-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.15);
    letter-spacing: 0.15em;
  }

  .dashboard-status {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: rgba(34, 197, 94, 0.45);
    padding: 0.1rem 0.45rem;
    border: 1px solid rgba(34, 197, 94, 0.12);
    border-radius: 3px;
    letter-spacing: 0.08em;
  }

  .dashboard-sync {
    font-family: var(--font-mono);
    font-size: 0.45rem;
    color: rgba(255, 255, 255, 0.12);
    letter-spacing: 0.08em;
  }

  /* ── SVG edges ── */
  .dashboard-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
  }

  .edge-line {
    transition: opacity 0.2s ease-out;
  }

  .edge-line.highlighted {
    opacity: 0.45 !important;
    stroke-width: 2 !important;
  }

  .edge-line.dimmed {
    opacity: 0.03 !important;
  }

  /* ── Edge labels ── */
  .edge-label {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 4;
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: rgba(255, 255, 255, 0.45);
    background: rgba(10, 10, 12, 0.85);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.9);
    transition: opacity 0.2s ease-out, transform 0.2s cubic-bezier(.2, .8, .2, 1);
  }

  .edge-label.visible {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  /* ── Project nodes ── */
  .dashboard-node {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 6;
    background: rgba(14, 14, 16, 0.72);
    border: 1px solid rgba(var(--node-color), 0.15);
    border-radius: 10px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.02);
    cursor: pointer;
    min-width: 175px;
    max-width: 175px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition:
      border-color 0.2s ease-out,
      transform 0.2s cubic-bezier(.2, .8, .2, 1),
      box-shadow 0.2s ease-out,
      opacity 0.15s ease-out,
      max-width 0.3s cubic-bezier(.2, .8, .2, 1);
    text-align: left;
    color: inherit;
    animation: node-enter 0.4s cubic-bezier(.2, .8, .2, 1) both;
    animation-delay: var(--node-delay, 0ms);
    overflow: hidden;
  }

  @keyframes node-enter {
    from { opacity: 0; transform: translate(-50%, -50%) scale(0.92); }
    to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  }

  .dashboard-node:hover:not(.dimmed) {
    border-color: rgba(var(--node-color), 0.4);
    transform: translate(-50%, -50%) scale(1.03);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 0 24px rgba(var(--node-color), 0.08),
      0 0 48px rgba(var(--node-color), 0.03);
    z-index: 8;
  }

  .dashboard-node.expanded {
    border-color: rgba(var(--node-color), 0.35);
    max-width: 320px;
    background: rgba(12, 12, 14, 0.9);
    transform: translate(-50%, -50%) scale(1);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 0 30px rgba(var(--node-color), 0.08),
      0 0 60px rgba(var(--node-color), 0.04);
    z-index: 10;
    cursor: default;
  }

  .dashboard-node.dimmed {
    opacity: 0.2;
    pointer-events: none;
  }

  /* ── Compact ── */
  .node-compact {
    padding: 0.6rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .node-top-row {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    overflow: hidden;
  }

  .node-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse var(--pulse-rate, 3s) ease-in-out infinite;
  }

  .node-status-dot[data-status="ONLINE"] {
    background: rgb(34, 197, 94);
    box-shadow: 0 0 6px rgba(34, 197, 94, 0.4);
  }
  .node-status-dot[data-status="DEPLOYING"] {
    background: rgb(234, 179, 8);
    box-shadow: 0 0 6px rgba(234, 179, 8, 0.4);
  }
  .node-status-dot[data-status="STANDBY"] {
    background: rgba(255, 255, 255, 0.2);
    box-shadow: 0 0 4px rgba(255, 255, 255, 0.1);
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.9; }
    50% { opacity: 0.25; }
  }

  .node-name {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(var(--node-color), 0.85);
    white-space: nowrap;
  }

  .node-status-label {
    font-family: var(--font-mono);
    font-size: 0.45rem;
    color: rgba(34, 197, 94, 0.35);
    letter-spacing: 0.1em;
    margin-left: auto;
    flex-shrink: 0;
  }
  .node-status-label.deploying { color: rgba(234, 179, 8, 0.45); }
  .node-status-label.standby { color: rgba(255, 255, 255, 0.12); }

  .node-tagline {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.22);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Detail ── */
  .node-detail {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    padding: 0 0.8rem;
    transition:
      max-height 0.3s cubic-bezier(.2, .8, .2, 1),
      opacity 0.25s ease-out,
      padding 0.3s ease-out;
  }

  .expanded .node-detail {
    max-height: 300px;
    opacity: 1;
    padding: 0 0.8rem 0.7rem;
  }

  .node-detail-badges {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 0.4rem;
    padding-top: 0.3rem;
    border-top: 1px solid rgba(var(--node-color), 0.08);
  }

  .node-badge {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    padding: 0.08rem 0.35rem;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .node-badge-wip {
    background: rgba(234, 179, 8, 0.12) !important;
    color: rgba(234, 179, 8, 0.7) !important;
  }

  .node-desc {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.38);
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }

  .node-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem;
    margin-bottom: 0.5rem;
  }

  .node-tech-pill {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    padding: 0.08rem 0.35rem;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.28);
    border-radius: 3px;
  }

