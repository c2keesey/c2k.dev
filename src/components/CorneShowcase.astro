---
// C2K-Corne — custom split keyboard with ZMK firmware
// Interactive keymap visualization with layer switching
---

<div class="crn-showcase">
  <div class="crn-card">
    <div class="crn-content">
      <div class="crn-header">
        <span class="crn-name text-scramble" data-text="C2K-Corne" data-delay="100" data-always="false">C2K-Corne</span>
        <span class="crn-badge">keyboard</span>
      </div>
      <p class="crn-tagline">42-key split keyboard</p>
      <p class="crn-desc">Custom Corne build running ZMK with urob's config. 7 layers, homerow mods, smart-shift, combos, mod-morphs, tri-state swappers, and app shortcuts — all on 42 keys.</p>

      <div class="crn-media">
        <img src="/corne.gif" alt="C2K-Corne keyboard" class="crn-photo" onerror="this.parentElement.style.display='none'" />
      </div>

      <div class="crn-keymap" id="crn-keymap">
        <div class="crn-layers" id="crn-layers">
          <button class="crn-layer-btn active" data-layer="base">base</button>
          <button class="crn-layer-btn" data-layer="nav">nav</button>
          <button class="crn-layer-btn" data-layer="fn">fn</button>
          <button class="crn-layer-btn" data-layer="num">num</button>
          <button class="crn-layer-btn" data-layer="sym">sym</button>
          <button class="crn-layer-btn" data-layer="sys">sys</button>
          <button class="crn-layer-btn" data-layer="combos">combos</button>
        </div>
        <div class="crn-board" id="crn-board"></div>
        <div class="crn-detail" id="crn-detail"></div>
      </div>

      <div class="crn-features">
        <span class="crn-feat">homerow mods</span>
        <span class="crn-feat">smart-shift</span>
        <span class="crn-feat">combos</span>
        <span class="crn-feat">mod-morphs</span>
        <span class="crn-feat">tri-state swappers</span>
        <span class="crn-feat">7 layers</span>
        <span class="crn-feat">tented</span>
      </div>

      <div class="crn-stack">
        <span class="crn-tech">ZMK</span>
        <span class="crn-tech">C</span>
        <span class="crn-tech">Devicetree</span>
        <span class="crn-tech">Bluetooth</span>
      </div>

      <div class="crn-footer">
        <span class="crn-pre-llm">hand-assembled · hand-configured · 2024</span>
        <div class="crn-footer-right">
          <span class="crn-stats" id="crn-stats"></span>
          <a class="crn-link" href="https://github.com/c2keesey/urob-zmk-config-corne" target="_blank" rel="noopener">github.com/c2keesey/urob-zmk-config-corne ↗</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Fetch GitHub stats
  fetch('https://api.github.com/repos/c2keesey/urob-zmk-config-corne')
    .then(r => r.json())
    .then(data => {
      const stars = data.stargazers_count ?? 0;
      const forks = data.forks_count ?? 0;
      const el = document.getElementById('crn-stats');
      if (el && (stars > 5 || forks > 5)) {
        const parts: string[] = [];
        if (stars > 5) parts.push(`★ ${stars}`);
        if (forks > 5) parts.push(`⑂ ${forks}`);
        el.textContent = parts.join('  ');
      }
    })
    .catch(() => {});

  function initCorne() {
    const board = document.getElementById('crn-board');
    const detail = document.getElementById('crn-detail');
    if (!board || !detail) return;

    type Key = { label: string; sub?: string; mod?: string; width?: number; detail?: string; };

    const layers: Record<string, { left: Key[][]; right: Key[][]; }> = {
      base: {
        left: [
          [{ label: 'Q' }, { label: 'W' }, { label: 'E' }, { label: 'R' }, { label: 'T' }],
          [{ label: 'A', sub: 'ctrl', mod: 'hrm', detail: 'Homerow mod: hold for Ctrl (balanced, 280ms)' }, { label: 'S', sub: 'alt', mod: 'hrm', detail: 'Homerow mod: hold for Alt' }, { label: 'D', sub: 'gui', mod: 'hrm', detail: 'Homerow mod: hold for Cmd' }, { label: 'F', sub: 'sft', mod: 'hrm', detail: 'Homerow mod: hold for Shift' }, { label: 'G' }],
          [{ label: 'Z' }, { label: 'X' }, { label: 'C' }, { label: 'V' }, { label: 'B' }],
        ],
        right: [
          [{ label: 'Y' }, { label: 'U' }, { label: 'I' }, { label: 'O' }, { label: 'P' }],
          [{ label: 'H' }, { label: 'J', sub: 'sft', mod: 'hrm', detail: 'Homerow mod: hold for Shift' }, { label: 'K', sub: 'gui', mod: 'hrm', detail: 'Homerow mod: hold for Cmd' }, { label: 'L', sub: 'alt', mod: 'hrm', detail: 'Homerow mod: hold for Alt' }, { label: "'", sub: 'ctrl', mod: 'hrm', detail: 'Homerow mod: hold for Ctrl' }],
          [{ label: 'N' }, { label: 'M' }, { label: ',', detail: 'Tap: , | Shift: ; | Ctrl+Shift: <' }, { label: '.', detail: 'Tap: . | Shift: : | Ctrl+Shift: >' }, { label: '/' }],
        ],
      },
      nav: {
        left: [
          [{ label: '' }, { label: 'WHSP', detail: 'Whisper hotkey (Hyper+1)' }, { label: '⇧Tab' }, { label: 'win↔', mod: 'nav', detail: 'Alt+Tab window swapper (tri-state)' }, { label: '' }],
          [{ label: '⌘[', sub: 'ctrl', mod: 'hrm', detail: 'Back | Hold: Ctrl' }, { label: '⌘]', sub: 'alt', mod: 'hrm', detail: 'Forward | Hold: Alt' }, { label: 'F5', sub: 'gui', mod: 'hrm', detail: 'Hold: Cmd' }, { label: 'F6', sub: 'sft', mod: 'hrm', detail: 'Hold: Shift' }, { label: '⌘D' }],
          [{ label: 'F16' }, { label: 'F4' }, { label: '←' }, { label: 'tab↔', mod: 'nav', detail: 'App tab swapper (tri-state)' }, { label: '' }],
        ],
        right: [
          [{ label: '' }, { label: '' }, { label: 'del', detail: 'Tap: DEL | Long: Ctrl+DEL (delete word forward)' }, { label: 'cancel' }, { label: '' }],
          [{ label: '' }, { label: '←', mod: 'nav' }, { label: '↓', mod: 'nav', detail: 'Alt+tap: 5x down' }, { label: '↑', mod: 'nav', detail: 'Alt+tap: 5x up' }, { label: '→', mod: 'nav' }],
          [{ label: '' }, { label: 'tab' }, { label: 'pgdn' }, { label: 'pgup' }, { label: '' }],
        ],
      },
      fn: {
        left: [
          [{ label: 'F12' }, { label: 'F7' }, { label: 'F8' }, { label: 'F9' }, { label: '' }],
          [{ label: 'F11', sub: 'ctrl', mod: 'hrm' }, { label: 'F4', sub: 'alt', mod: 'hrm' }, { label: 'F5', sub: 'gui', mod: 'hrm' }, { label: 'F6', sub: 'sft', mod: 'hrm' }, { label: '' }],
          [{ label: 'F10' }, { label: 'F1' }, { label: 'F2' }, { label: 'F3' }, { label: '' }],
        ],
        right: [
          [{ label: '' }, { label: '' }, { label: '' }, { label: '' }, { label: '' }],
          [{ label: '' }, { label: '⏮', mod: 'nav' }, { label: '🔉', detail: 'Volume down | Hold: Ctrl' }, { label: '🔊' }, { label: '⏭', mod: 'nav' }],
          [{ label: 'pin◉', detail: 'Pin app (⌘⌃⇧A)' }, { label: 'pin◫', detail: 'Pin window (⌘⌃⇧Q)' }, { label: 'desk', detail: 'Desktop manager (Alt+`)' }, { label: '' }, { label: '' }],
        ],
      },
      num: {
        left: [
          [{ label: '' }, { label: '7' }, { label: '8' }, { label: '9' }, { label: '' }],
          [{ label: '0', sub: 'ctrl', mod: 'hrm' }, { label: '4', sub: 'alt', mod: 'hrm' }, { label: '5', sub: 'gui', mod: 'hrm' }, { label: '6', sub: 'sft', mod: 'hrm' }, { label: '' }],
          [{ label: '' }, { label: '1' }, { label: '2' }, { label: '3' }, { label: '' }],
        ],
        right: [
          [{ label: '' }, { label: '' }, { label: '' }, { label: '' }, { label: '' }],
          [{ label: '' }, { label: '' }, { label: '' }, { label: '' }, { label: '' }],
          [{ label: '' }, { label: '' }, { label: '' }, { label: '' }, { label: '' }],
        ],
      },
      sym: {
        left: [
          [{ label: '⌘Q', detail: 'Quit app' }, { label: 'M1', detail: 'Hyper+2 macro' }, { label: 'M2', detail: 'Hyper+3 macro' }, { label: 'M3', detail: 'Hyper+4 macro' }, { label: 'M4', detail: 'Hyper+5 macro' }],
          [{ label: 'F2', sub: 'ctrl', mod: 'hrm', detail: 'Rename | Hold: Ctrl' }, { label: '⌘W', sub: 'alt', mod: 'hrm', detail: 'Close tab | Hold: Alt' }, { label: '⌘T', sub: 'gui', mod: 'hrm', detail: 'New tab | Hold: Cmd' }, { label: '⌘R', sub: 'sft', mod: 'hrm', detail: 'Reload | Hold: Shift' }, { label: '⌘⇧T', detail: 'Reopen closed tab' }],
          [{ label: '⌘F', detail: 'Find' }, { label: '⌘S', detail: 'Save' }, { label: '⌘Z', detail: 'Undo' }, { label: '⌘⇧Z', detail: 'Redo' }, { label: 'F3' }],
        ],
        right: [
          [{ label: '`' }, { label: '&' }, { label: '|' }, { label: '~' }, { label: '\\' }],
          [{ label: '' }, { label: '#', sub: 'sft', mod: 'hrm' }, { label: '@', sub: 'gui', mod: 'hrm' }, { label: '+', sub: 'alt', mod: 'hrm' }, { label: '*', sub: 'ctrl', mod: 'hrm' }],
          [{ label: '' }, { label: '^' }, { label: '%' }, { label: '$' }, { label: '!' }],
        ],
      },
      sys: {
        left: [
          [{ label: 'BT0', mod: 'mod', detail: 'Bluetooth profile 0' }, { label: 'BT1', mod: 'mod', detail: 'Bluetooth profile 1' }, { label: 'BT2', mod: 'mod', detail: 'Bluetooth profile 2' }, { label: 'BT3', mod: 'mod', detail: 'Bluetooth profile 3' }, { label: 'CLR', mod: 'mod', detail: 'Clear bluetooth' }],
          [{ label: '' }, { label: '' }, { label: '' }, { label: '' }, { label: 'boot', mod: 'mod', detail: 'Bootloader mode' }],
          [{ label: '' }, { label: '' }, { label: '' }, { label: '' }, { label: 'reset', mod: 'mod', detail: 'System reset' }],
        ],
        right: [
          [{ label: '' }, { label: '' }, { label: '' }, { label: '' }, { label: '' }],
          [{ label: 'boot', mod: 'mod', detail: 'Bootloader mode' }, { label: '' }, { label: '' }, { label: '' }, { label: '' }],
          [{ label: 'reset', mod: 'mod', detail: 'System reset' }, { label: '' }, { label: '' }, { label: '' }, { label: '' }],
        ],
      },
    };

    const thumbs: Record<string, { left: Key[]; right: Key[]; }> = {
      base: {
        left: [{ label: 'esc', sub: 'fn', detail: 'Tap: Esc | Hold: FN layer' }, { label: 'spc', sub: 'nav', detail: 'Tap: Space | Hold: NAV layer | Shift: dot + space + sticky shift' }, { label: 'tab', sub: 'sym', detail: 'Tap: Tab | Hold: SYM layer' }],
        right: [{ label: 'ret', sub: 'sys', detail: 'Tap: Return | Hold: SYS layer' }, { label: 'bspc', sub: 'num', detail: 'Tap: Bspc | Hold: NUM layer | Shift: DEL' }, { label: '\u21e7', detail: 'Smart shift: tap = sticky shift, double-tap = caps word' }],
      },
      nav: { left: [{ label: '' }, { label: '\u2593', mod: 'active' }, { label: '' }], right: [{ label: 'ret' }, { label: 'bspc', detail: 'Tap: Bspc | Long: Ctrl+Bspc (delete word)' }, { label: '\u21e7' }] },
      fn: { left: [{ label: '\u2593', mod: 'active' }, { label: '' }, { label: '' }], right: [{ label: '⏹', detail: 'Mute' }, { label: '⏯', detail: 'Play/pause' }, { label: '\u21e7' }] },
      num: { left: [{ label: '_', detail: 'Underscore' }, { label: 'spc' }, { label: '' }], right: [{ label: '' }, { label: '\u2593', mod: 'active' }, { label: '\u21e7' }] },
      sym: { left: [{ label: '' }, { label: '' }, { label: '\u2593', mod: 'active' }], right: [{ label: 'ret' }, { label: 'bspc' }, { label: '\u21e7' }] },
      sys: { left: [{ label: '' }, { label: '' }, { label: '' }], right: [{ label: '\u2593', mod: 'active' }, { label: '' }, { label: '' }] },
    };

    // Combo definitions: between columns c1 and c2 at row r, on side L/R
    // Adjacent combos go between the two columns; non-adjacent span across
    interface ComboData { side: string; row: number; c1: number; c2: number; output: string; detail: string; }
    const comboData: ComboData[] = [
      { side: 'L', row: 0, c1: 0, c2: 1, output: ':', detail: 'Q + W → colon' },
      { side: 'L', row: 0, c1: 1, c2: 2, output: '=', detail: 'W + E → equals' },
      { side: 'L', row: 1, c1: 1, c2: 2, output: 'bspc', detail: 'S + D → backspace | Hold: Alt+Gui' },
      { side: 'L', row: 1, c1: 2, c2: 3, output: 'ret', detail: 'D + F → return | Hold: Shift+Gui' },
      { side: 'L', row: 2, c1: 1, c2: 2, output: 'copy', detail: 'X + C → copy | 2x: all + copy' },
      { side: 'L', row: 2, c1: 2, c2: 3, output: 'paste', detail: 'C + V → paste | 2x: all + paste' },
      { side: 'L', row: 2, c1: 1, c2: 3, output: 'cut', detail: 'X + V → cut (skips C)' },
      { side: 'L', row: 1, c1: 1, c2: 3, output: '⌘A', detail: 'F + S → select all (skips D)' },
      { side: 'R', row: 0, c1: 1, c2: 2, output: '_', detail: 'U + I → underscore' },
      { side: 'R', row: 0, c1: 2, c2: 3, output: '-', detail: 'I + O → minus' },
      { side: 'R', row: 1, c1: 1, c2: 2, output: '(', detail: 'J + K → ( | Shift: <' },
      { side: 'R', row: 1, c1: 2, c2: 3, output: ')', detail: 'K + L → )' },
      { side: 'R', row: 2, c1: 1, c2: 2, output: '[', detail: 'M + , → [ | NAV: {' },
      { side: 'R', row: 2, c1: 2, c2: 3, output: ']', detail: ', + . → ] | NAV: }' },
    ];

    // Build set of keys involved in combos for highlighting
    const comboKeySet = new Set<string>();
    comboData.forEach(c => {
      comboKeySet.add(`${c.side}-${c.row}-${c.c1}`);
      comboKeySet.add(`${c.side}-${c.row}-${c.c2}`);
    });

    const keyNames: Record<string, string[][]> = {
      L: [['Q','W','E','R','T'],['A','S','D','F','G'],['Z','X','C','V','B']],
      R: [['Y','U','I','O','P'],['H','J','K','L',"'"],['N','M',',','.','/']],
    };

    let currentLayer = 'base';

    // ── Key label scramble on layer switch ──
    const scrambleChars = '0123456789abcdefABCDEF~#$%&';

    function scrambleKeys(container: HTMLElement) {
      const labels = container.querySelectorAll<HTMLElement>('.crn-key-label');
      const duration = 350;

      labels.forEach((label, i) => {
        const target = label.textContent || '';
        if (!target.trim()) return;

        // Stagger: top-left resolves first, bottom-right last
        const row = Math.floor(i / 5);
        const col = i % 5;
        const delay = row * 30 + col * 20;

        label.textContent = target.replace(/[^ ]/g, '–');

        setTimeout(() => {
          let start: number | null = null;
          const step = (ts: number) => {
            if (!start) start = ts;
            const elapsed = ts - start;
            const progress = Math.min(elapsed / duration, 1);

            let out = '';
            for (let c = 0; c < target.length; c++) {
              if (target[c] === ' ') out += ' ';
              // Resolve threshold: 0.55-0.85 range so short labels still scramble visibly
              else if (progress > 0.55 + (c / Math.max(target.length, 1)) * 0.3) out += target[c];
              else if (progress > 0.08) out += scrambleChars[Math.floor(Math.random() * scrambleChars.length)];
              else out += '–';
            }
            label.textContent = out;
            if (elapsed < duration) requestAnimationFrame(step);
            else label.textContent = target;
          };
          requestAnimationFrame(step);
        }, delay);
      });
    }

    function renderBoard() {
      const isComboView = currentLayer === 'combos';
      const layerName = isComboView ? 'base' : currentLayer;
      const layer = layers[layerName];
      const thumb = thumbs[layerName];
      while (board.firstChild) board.removeChild(board.firstChild);

      const container = document.createElement('div');
      container.className = 'crn-halves';

      function renderHalf(rows: Key[][], thumbKeys: Key[], isRight: boolean): HTMLElement {
        const half = document.createElement('div');
        half.className = 'crn-half' + (isRight ? ' crn-right' : ' crn-left');
        const side = isRight ? 'R' : 'L';

        const stagger = [8, 3, 0, 3, 6];
        const cols = rows[0].length;
        const colContainer = document.createElement('div');
        colContainer.className = 'crn-cols';

        for (let c = 0; c < cols; c++) {
          const colEl = document.createElement('div');
          colEl.className = 'crn-col';
          const sIdx = isRight ? (cols - 1 - c) : c;
          colEl.style.marginTop = (stagger[sIdx] || 0) + 'px';

          for (let r = 0; r < rows.length; r++) {
            const keyEl = makeKey(rows[r][c], false, false);
            // Highlight combo keys
            if (isComboView && comboKeySet.has(`${side}-${r}-${c}`)) {
              keyEl.classList.add('crn-combo-key');
            } else if (isComboView) {
              keyEl.classList.add('crn-dimmed');
            }
            colEl.appendChild(keyEl);
          }
          colContainer.appendChild(colEl);
        }
        half.appendChild(colContainer);

        const thumbRow = document.createElement('div');
        thumbRow.className = 'crn-row crn-thumbs';
        thumbKeys.forEach(key => {
          const keyEl = makeKey(key, true, false);
          if (isComboView) keyEl.classList.add('crn-dimmed');
          half.appendChild(keyEl); // temp
        });
        // Clear and redo thumbs properly
        const realThumbRow = document.createElement('div');
        realThumbRow.className = 'crn-row crn-thumbs';
        thumbKeys.forEach(key => {
          const keyEl = makeKey(key, true, false);
          if (isComboView) keyEl.classList.add('crn-dimmed');
          realThumbRow.appendChild(keyEl);
        });
        // Remove the wrongly appended ones
        while (half.childNodes.length > 1) {
          const last = half.lastChild;
          if (last && last !== colContainer) half.removeChild(last);
          else break;
        }
        half.appendChild(realThumbRow);

        return half;
      }

      container.appendChild(renderHalf(layer.left, thumb.left, false));
      container.appendChild(renderHalf(layer.right, thumb.right, true));
      board.appendChild(container);

      // Render combo legend below keyboard
      if (isComboView) {
        const legend = document.createElement('div');
        legend.className = 'crn-combo-legend';

        comboData.forEach(c => {
          const row = document.createElement('div');
          row.className = 'crn-combo-row';

          const keys = document.createElement('span');
          keys.className = 'crn-combo-keys';
          keys.textContent = `${keyNames[c.side][c.row][c.c1]} + ${keyNames[c.side][c.row][c.c2]}`;

          const arrow = document.createElement('span');
          arrow.className = 'crn-combo-arrow';
          arrow.textContent = '→';

          const output = document.createElement('span');
          output.className = 'crn-combo-output';
          output.textContent = c.output;

          row.appendChild(keys);
          row.appendChild(arrow);
          row.appendChild(output);

          addComboInteraction(row, c.detail);
          legend.appendChild(row);
        });

        board.appendChild(legend);
      }
    }

    function addComboInteraction(el: HTMLElement, comboDetail: string) {
      let isTouch = false;
      el.addEventListener('pointerdown', (e) => { isTouch = e.pointerType === 'touch'; });
      el.addEventListener('mouseenter', () => {
        if (isTouch) return;
        detail.textContent = comboDetail;
        detail.classList.add('visible');
      });
      el.addEventListener('mouseleave', () => {
        if (isTouch) return;
        detail.classList.remove('visible');
      });
      el.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const wasVisible = detail.classList.contains('visible') && detail.textContent === comboDetail;
        detail.textContent = comboDetail;
        if (wasVisible) detail.classList.remove('visible');
        else detail.classList.add('visible');
      });
    }

    function makeKey(key: Key, isThumb = false, dimmed = false): HTMLElement {
      const el = document.createElement('div');
      el.className = 'crn-key' + (isThumb ? ' crn-thumb' : '') + (key.mod ? ` crn-${key.mod}` : '') + (!key.label ? ' crn-empty' : '') + (dimmed ? ' crn-dimmed' : '');

      const label = document.createElement('span');
      label.className = 'crn-key-label';
      label.textContent = key.label;
      el.appendChild(label);

      if (key.sub && !dimmed) {
        const sub = document.createElement('span');
        sub.className = 'crn-key-sub';
        sub.textContent = key.sub;
        el.appendChild(sub);
      }

      if (key.detail && !dimmed) {
        let keyIsTouch = false;

        el.addEventListener('pointerdown', (e) => {
          keyIsTouch = e.pointerType === 'touch';
        });

        el.addEventListener('mouseenter', () => {
          if (keyIsTouch) return;
          detail.textContent = key.detail!;
          detail.classList.add('visible');
        });
        el.addEventListener('mouseleave', () => {
          if (keyIsTouch) return;
          detail.classList.remove('visible');
        });
        el.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const wasVisible = detail.classList.contains('visible') && detail.textContent === key.detail;
          detail.textContent = key.detail!;
          if (wasVisible) {
            detail.classList.remove('visible');
          } else {
            detail.classList.add('visible');
          }
        });
      }

      return el;
    }

    // Layer switching
    document.querySelectorAll<HTMLButtonElement>('.crn-layer-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const layer = btn.dataset.layer;
        if (layer) {
          currentLayer = layer;
          document.querySelectorAll('.crn-layer-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          detail.classList.remove('visible');
          renderBoard();
          scrambleKeys(board);
        }
      });
    });

    renderBoard();
  }

  initCorne();
</script>

<style>
  .crn-showcase {
    margin-bottom: 2rem;
  }

  .crn-card {
    display: block;
    position: relative;
    background: var(--bg-glass);
    border: 1px solid rgba(6, 182, 212, 0.12);
    border-radius: 12px;
    padding: 1.75rem;
    overflow: hidden;
    color: var(--text);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: inset 0 1px 0 0 var(--glass-highlight), var(--card-shadow);
  }

  .crn-content {
    position: relative;
    z-index: 1;
  }

  .crn-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .crn-name {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: rgba(6, 182, 212, 0.9);
  }

  .crn-badge {
    font-family: var(--font-mono);
