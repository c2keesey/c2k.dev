---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  showLab?: boolean;
}

const { showLab = false } = Astro.props;

const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/log', label: 'Log' },
  { href: '/about', label: 'About' },
  ...(showLab ? [{ href: '/lab', label: 'Lab' }] : []),
];
---

<!-- Desktop top nav -->
<nav class="top-nav">
  <div class="nav-inner">
    <a href="/" class="logo">C2K</a>
    <div class="nav-links" id="nav-links">
      {links.map(link => (
        <a href={link.href} class="nav-link">
          {link.label}
        </a>
      ))}
      <div class="nav-indicator" id="nav-indicator"></div>
    </div>
    <ThemeToggle />
  </div>
</nav>

<!-- Mobile bottom nav -->
<nav class="bottom-nav" id="bottom-nav">
  <div class="bottom-nav-bar" id="bottom-nav-pill">
    <div class="bottom-nav-highlight" id="bottom-nav-highlight"></div>
    <button class="bottom-tab" data-index="0" aria-label="Home">
      <svg class="tab-icon icon-beacon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2">
        <circle cx="8" cy="8" r="2" fill="currentColor" stroke="none" class="beacon-core"></circle>
        <path class="beacon-wave beacon-wave-1" d="M4.5 4.5a5 5 0 0 1 7 0" stroke-linecap="round"></path>
        <path class="beacon-wave beacon-wave-2" d="M2.5 2.5a8 8 0 0 1 11 0" stroke-linecap="round"></path>
        <path class="beacon-wave beacon-wave-1" d="M4.5 11.5a5 5 0 0 0 7 0" stroke-linecap="round"></path>
        <path class="beacon-wave beacon-wave-2" d="M2.5 13.5a8 8 0 0 0 11 0" stroke-linecap="round"></path>
      </svg>
      <span class="tab-label">Home</span>
    </button>
    <button class="bottom-tab" data-index="1" aria-label="Projects">
      <svg class="tab-icon icon-nodes" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2">
        <line class="node-edge" x1="8" y1="4" x2="4" y2="10"></line>
        <line class="node-edge" x1="8" y1="4" x2="12" y2="10"></line>
        <line class="node-edge" x1="4" y1="10" x2="12" y2="10"></line>
        <circle class="node node-1" cx="8" cy="4" r="2" fill="currentColor" stroke="none"></circle>
        <circle class="node node-2" cx="4" cy="10" r="2" fill="currentColor" stroke="none"></circle>
        <circle class="node node-3" cx="12" cy="10" r="2" fill="currentColor" stroke="none"></circle>
      </svg>
      <span class="tab-label">Systems</span>
    </button>
    <button class="bottom-tab" data-index="2" aria-label="Log">
      <svg class="tab-icon icon-signal" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2">
        <path class="signal-wave signal-wave-1" d="M2 10V8" stroke-linecap="round"></path>
        <path class="signal-wave signal-wave-2" d="M5 10V6" stroke-linecap="round"></path>
        <path class="signal-wave signal-wave-3" d="M8 10V4" stroke-linecap="round"></path>
        <path class="signal-wave signal-wave-2" d="M11 10V6" stroke-linecap="round"></path>
        <path class="signal-wave signal-wave-1" d="M14 10V8" stroke-linecap="round"></path>
      </svg>
      <span class="tab-label">Log</span>
    </button>
    <button class="bottom-tab" data-index="3" aria-label="About">
      <svg class="tab-icon icon-terminal" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2">
        <path class="terminal-chevron" d="M3 5l4 3-4 3" stroke-linecap="round" stroke-linejoin="round"></path>
        <line class="terminal-cursor" x1="9" y1="12" x2="13" y2="12" stroke-linecap="round"></line>
      </svg>
      <span class="tab-label">About</span>
    </button>
    {showLab && (
      <button class="bottom-tab" data-index="4" aria-label="Lab">
        <svg class="tab-icon icon-lab" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M6 2v4L3 12a1 1 0 001 1h8a1 1 0 001-1l-3-6V2" stroke-linecap="round" stroke-linejoin="round"></path>
          <line x1="5" y1="2" x2="11" y2="2" stroke-linecap="round"></line>
          <circle class="lab-bubble lab-bubble-1" cx="7" cy="10" r="1" fill="currentColor" stroke="none"></circle>
          <circle class="lab-bubble lab-bubble-2" cx="9.5" cy="11" r="0.7" fill="currentColor" stroke="none"></circle>
        </svg>
        <span class="tab-label">Lab</span>
      </button>
    )}
  </div>
</nav>

<style>
  /* ── Desktop top nav ── */
  .top-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-nav);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  @media (min-width: 1024px) {
    .nav-inner {
      max-width: 92%;
    }
  }

  .logo {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 800;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-links {
    display: flex;
    gap: 0;
    position: relative;
  }

  .nav-link {
    padding: 0.4rem 0.75rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color 0.2s;
    position: relative;
    z-index: 1;
    cursor: pointer;
  }

  .nav-link:hover {
    color: var(--text);
  }

  .nav-indicator {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 100%;
    background: var(--bg-hover);
    border-radius: 6px;
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }

  /* Hide top nav links on mobile (keep logo) */
  @media (max-width: 767px) {
    .nav-links {
      display: none;
    }
  }

  /* ── Mobile bottom nav ── */
  .bottom-nav {
    display: none;
  }

  @media (max-width: 767px) {
    .bottom-nav {
      display: flex;
      justify-content: center;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 0 0 calc(36px + env(safe-area-inset-bottom, 0px));
      pointer-events: none;
    }

    .bottom-nav-bar {
      display: flex;
      align-items: center;
      position: relative;
      width: 272px;
      padding: 4px;
      background: var(--bg-glass-heavy);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: 10px;
      border: 1px solid var(--glass-border);
      box-shadow: inset 0 1px 0 0 var(--glass-highlight);
      pointer-events: auto;
    }

    .bottom-nav-highlight {
      position: absolute;
      top: 4px;
      height: calc(100% - 8px);
      border-radius: 7px;
      background: var(--purple-bg-subtle);
      border: 1px solid var(--glass-border);
      pointer-events: none;
      transition: left 300ms cubic-bezier(.4, 0, .2, 1),
                  width 300ms cubic-bezier(.4, 0, .2, 1);
      will-change: left, width;
    }

    .bottom-tab {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      height: 38px;
      flex: 1 1 0;
      min-width: 0;
      padding: 0;
      border: none;
      background: transparent;
      color: var(--text-muted);
      cursor: pointer;
      border-radius: 7px;
      position: relative;
      z-index: 1;
      transition: color 250ms ease-out,
                  flex 300ms cubic-bezier(.4, 0, .2, 1);
      -webkit-tap-highlight-color: transparent;
    }

    .tab-icon {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }

    .tab-label {
      font-family: var(--font-mono);
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      white-space: nowrap;
      overflow: hidden;
      max-width: 0;
      opacity: 0;
      transition: max-width 300ms cubic-bezier(.4, 0, .2, 1),
                  opacity 120ms ease-out;
    }

    /* Active state */
    .bottom-tab[data-active="true"] {
      color: var(--purple);
      flex: 2.2 1 0;
    }

    .bottom-tab[data-active="true"] .tab-label {
      max-width: 70px;
      opacity: 1;
      transition: max-width 300ms cubic-bezier(.4, 0, .2, 1),
                  opacity 250ms ease-in-out 60ms;
    }

    /* ── Icon animations on active ── */

    /* Beacon: inactive = dim waves */
    .beacon-wave { opacity: 0.15; transition: opacity 300ms ease-out; }
    .beacon-core { transition: transform 300ms ease-out; transform-origin: center; }
    .bottom-tab[data-active="true"] .beacon-wave-1 {
      animation: beacon-pulse 2s ease-in-out infinite;
    }
    .bottom-tab[data-active="true"] .beacon-wave-2 {
      animation: beacon-pulse 2s ease-in-out 0.3s infinite;
    }

    @keyframes beacon-pulse {
      0%, 100% { opacity: 0.2; }
      50% { opacity: 0.8; }
    }

    /* Nodes: inactive = dim edges, active = edges light up + nodes pulse */
    .node-edge { opacity: 0.15; transition: opacity 300ms ease-out; }
    .node { transform-origin: center; transform-box: fill-box; }
    .bottom-tab[data-active="true"] .node-edge { opacity: 0.4; }
    .bottom-tab[data-active="true"] .node-1 {
      animation: node-ping 1.8s ease-in-out infinite;
    }
    .bottom-tab[data-active="true"] .node-2 {
      animation: node-ping 1.8s ease-in-out 0.4s infinite;
    }
    .bottom-tab[data-active="true"] .node-3 {
      animation: node-ping 1.8s ease-in-out 0.8s infinite;
    }

    @keyframes node-ping {
      0%, 100% { opacity: 0.35; }
      50% { opacity: 1; }
    }

    /* Signal: wave bounce on active */
    .signal-wave { opacity: 0.4; transition: opacity 300ms ease-out; }
    .bottom-tab[data-active="true"] .signal-wave-1 {
      animation: signal-bounce 1.6s ease-in-out infinite;
    }
    .bottom-tab[data-active="true"] .signal-wave-2 {
      animation: signal-bounce 1.6s ease-in-out 0.2s infinite;
    }
    .bottom-tab[data-active="true"] .signal-wave-3 {
      animation: signal-bounce 1.6s ease-in-out 0.4s infinite;
    }

    @keyframes signal-bounce {
      0%, 100% { opacity: 0.25; }
      50% { opacity: 0.9; }
    }

    /* Terminal: cursor blink */
    .terminal-cursor { transition: opacity 300ms ease-out; }
    .bottom-tab[data-active="true"] .terminal-cursor {
      animation: cursor-blink 1s step-end infinite;
    }

    @keyframes cursor-blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
  }
</style>

<script>
  function initBottomNav() {
    const bottomNav = document.getElementById('bottom-nav');
    if (!bottomNav) return;

    const tabs = bottomNav.querySelectorAll<HTMLButtonElement>('.bottom-tab');
    const highlight = document.getElementById('bottom-nav-highlight') as HTMLElement;

    // Pure math — no DOM measurement needed
    // Dynamically compute based on actual tab count (4 or 5)
    const PADDING = 4;
    const TAB_COUNT = tabs.length;
    const BAR_WIDTH = TAB_COUNT === 5 ? 320 : 272;
    const INNER = BAR_WIDTH - PADDING * 2;
    const FLEX_INACTIVE = 1;
    const FLEX_ACTIVE = 2.2;
    const TOTAL_FLEX = FLEX_INACTIVE * (TAB_COUNT - 1) + FLEX_ACTIVE;
    const W_INACTIVE = INNER / TOTAL_FLEX * FLEX_INACTIVE;
    const W_ACTIVE = INNER / TOTAL_FLEX * FLEX_ACTIVE;

    // Update bar width if we have 5 tabs
    const bar = document.getElementById('bottom-nav-pill') as HTMLElement;
    if (bar && TAB_COUNT === 5) bar.style.width = `${BAR_WIDTH}px`;

    function moveHighlight(index: number) {
      if (!highlight) return;
      // Active tab position = padding + (inactive tabs before it) * W_INACTIVE
      const left = PADDING + index * W_INACTIVE;
      highlight.style.left = `${left}px`;
      highlight.style.width = `${W_ACTIVE}px`;
    }

    function setActiveTab(index: number) {
      tabs.forEach((tab, i) => {
        tab.setAttribute('data-active', String(i === index));
      });
      moveHighlight(index);
    }

    // Determine initial active tab from URL
    const pages = TAB_COUNT === 5
      ? ['/', '/projects', '/log', '/about', '/lab']
      : ['/', '/projects', '/log', '/about'];
    const path = location.pathname;
    const activeIdx = Math.max(0, pages.findIndex(p =>
      p === '/' ? path === '/' || path === '' : path.startsWith(p)
    ));

    // Set initial state without transitions
    if (highlight) highlight.style.transition = 'none';
    tabs.forEach((tab, i) => {
      tab.setAttribute('data-active', String(i === activeIdx));
      const label = tab.querySelector('.tab-label') as HTMLElement;
      if (label && i === activeIdx) {
        label.style.transition = 'none';
        label.style.opacity = '1';
      }
    });
    moveHighlight(activeIdx);
    requestAnimationFrame(() => {
      if (highlight) highlight.style.transition = '';
      tabs.forEach((tab) => {
        const label = tab.querySelector('.tab-label') as HTMLElement;
        if (label) { label.style.transition = ''; label.style.opacity = ''; }
      });
    });

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const index = parseInt(tab.dataset.index || '0', 10);
        setActiveTab(index);
        window.dispatchEvent(new CustomEvent('nav:goto', { detail: { index } }));
      });
    });

    window.addEventListener('nav:update', ((e: CustomEvent) => {
      setActiveTab(e.detail.index);
    }) as EventListener);
  }

  initBottomNav();
  document.addEventListener('astro:after-swap', initBottomNav);
</script>
