---
const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];
---

<!-- Desktop top nav -->
<nav class="top-nav">
  <div class="nav-inner">
    <a href="/" class="logo">C2K</a>
    <div class="nav-links" id="nav-links">
      {links.map(link => (
        <a href={link.href} class="nav-link">
          {link.label}
        </a>
      ))}
      <div class="nav-indicator" id="nav-indicator"></div>
    </div>
  </div>
</nav>

<!-- Mobile bottom nav -->
<nav class="bottom-nav" id="bottom-nav">
  <div class="bottom-nav-pill" id="bottom-nav-pill">
    <div class="bottom-nav-highlight" id="bottom-nav-highlight"></div>
    <button class="bottom-tab" data-index="0" aria-label="Home">
      <svg class="tab-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
      <span class="tab-label">Home</span>
    </button>
    <button class="bottom-tab" data-index="1" aria-label="Projects">
      <svg class="tab-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="7" height="7"></rect>
        <rect x="14" y="3" width="7" height="7"></rect>
        <rect x="14" y="14" width="7" height="7"></rect>
        <rect x="3" y="14" width="7" height="7"></rect>
      </svg>
      <span class="tab-label">Projects</span>
    </button>
    <button class="bottom-tab" data-index="2" aria-label="About">
      <svg class="tab-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
        <circle cx="12" cy="7" r="4"></circle>
      </svg>
      <span class="tab-label">About</span>
    </button>
  </div>
</nav>

<style>
  /* ── Desktop top nav ── */
  .top-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 11, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  @media (min-width: 1024px) {
    .nav-inner {
      max-width: 92%;
    }
  }

  .logo {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 800;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-links {
    display: flex;
    gap: 0;
    position: relative;
  }

  .nav-link {
    padding: 0.4rem 0.75rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color 0.2s;
    position: relative;
    z-index: 1;
    cursor: pointer;
  }

  .nav-link:hover {
    color: var(--text);
  }

  .nav-indicator {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 100%;
    background: var(--bg-hover);
    border-radius: 6px;
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }

  /* Hide top nav links on mobile (keep logo) */
  @media (max-width: 767px) {
    .nav-links {
      display: none;
    }
  }

  /* ── Mobile bottom nav ── */
  .bottom-nav {
    display: none;
  }

  @media (max-width: 767px) {
    .bottom-nav {
      display: flex;
      justify-content: center;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 0 0 calc(20px + env(safe-area-inset-bottom, 0px));
      pointer-events: none;
    }

    .bottom-nav-pill {
      display: flex;
      align-items: center;
      position: relative;
      gap: 2px;
      padding: 5px;
      background: rgba(28, 28, 32, 0.92);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-radius: 22px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4),
                  0 0 0 0.5px rgba(255, 255, 255, 0.04) inset;
      pointer-events: auto;
    }

    .bottom-nav-highlight {
      position: absolute;
      top: 5px;
      height: calc(100% - 10px);
      border-radius: 16px;
      background: rgba(168, 85, 247, 0.13);
      pointer-events: none;
      transition: left 300ms cubic-bezier(.4, 0, .2, 1),
                  width 300ms cubic-bezier(.4, 0, .2, 1);
      will-change: left, width;
    }

    .bottom-tab {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      height: 42px;
      padding: 0 16px;
      border: none;
      background: transparent;
      color: rgba(255, 255, 255, 0.35);
      cursor: pointer;
      border-radius: 16px;
      position: relative;
      z-index: 1;
      transition: color 250ms ease-out;
      -webkit-tap-highlight-color: transparent;
    }

    .tab-icon {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
    }

    .tab-label {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.03em;
      text-transform: capitalize;
      white-space: nowrap;
      overflow: hidden;
      width: 0;
      opacity: 0;
      transition: none;
    }

    /* Active state */
    .bottom-tab[data-active="true"] {
      color: var(--purple);
    }

    .bottom-tab[data-active="true"] .tab-label {
      width: auto;
      opacity: 1;
      transition: opacity 150ms ease-out 80ms;
    }
  }
</style>

<script>
  function initBottomNav() {
    const bottomNav = document.getElementById('bottom-nav');
    if (!bottomNav) return;

    const pill = document.getElementById('bottom-nav-pill') as HTMLElement;
    const tabs = bottomNav.querySelectorAll<HTMLButtonElement>('.bottom-tab');
    const highlight = document.getElementById('bottom-nav-highlight') as HTMLElement;

    function moveHighlight(index: number) {
      if (!highlight || !pill) return;
      const tab = tabs[index];
      if (!tab) return;
      const pillRect = pill.getBoundingClientRect();
      const tabRect = tab.getBoundingClientRect();
      highlight.style.left = `${tabRect.left - pillRect.left}px`;
      highlight.style.width = `${tabRect.width}px`;
    }

    function setActiveTab(index: number) {
      tabs.forEach((tab, i) => {
        tab.setAttribute('data-active', String(i === index));
      });
      // Force reflow so display:none/block takes effect, then measure
      pill.offsetHeight;
      moveHighlight(index);
    }

    // Determine initial active tab from URL
    const pages = ['/', '/projects', '/about'];
    const path = location.pathname;
    const initialIndex = pages.findIndex(p =>
      p === '/' ? path === '/' || path === '' : path.startsWith(p)
    );

    // Set initial state without any transitions
    if (highlight) highlight.style.transition = 'none';
    // Force labels to appear instantly on first render
    const activeIdx = Math.max(0, initialIndex);
    tabs.forEach((tab, i) => {
      tab.setAttribute('data-active', String(i === activeIdx));
      const label = tab.querySelector('.tab-label') as HTMLElement;
      if (label && i === activeIdx) {
        label.style.transition = 'none';
        label.style.opacity = '1';
      }
    });
    pill.offsetHeight;
    moveHighlight(activeIdx);
    requestAnimationFrame(() => {
      if (highlight) highlight.style.transition = '';
      tabs.forEach((tab) => {
        const label = tab.querySelector('.tab-label') as HTMLElement;
        if (label) label.style.transition = '';
        if (label) label.style.opacity = '';
      });
    });

    // Listen for clicks
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const index = parseInt(tab.dataset.index || '0', 10);
        setActiveTab(index);
        window.dispatchEvent(new CustomEvent('nav:goto', { detail: { index } }));
      });
    });

    // Listen for scroll-driven page changes
    window.addEventListener('nav:update', ((e: CustomEvent) => {
      setActiveTab(e.detail.index);
    }) as EventListener);
  }

  initBottomNav();
  document.addEventListener('astro:after-swap', initBottomNav);
</script>
