---
// Music — Full Spotify organizational system showcase
// Philosophy, flow system, genre worlds, automation pipeline
---

<!-- Philosophy -->
<section class="music-section">
  <div class="music-philosophy">
    <p class="music-philosophy-text">Songs flow downhill into specific playlists, then cascade uphill through the hierarchy automatically. Curate the leaves — the tree takes care of itself.</p>
  </div>
</section>

<!-- Song Lifecycle -->
<section class="music-section">
  <h2 class="music-section-title text-scramble" data-text="The Pipeline" data-delay="150" data-always="false">The Pipeline</h2>
  <p class="music-section-desc">Every song follows the same path from discovery to its permanent home.</p>

  <div class="pipeline" id="pipeline">
    <div class="pipeline-stage" data-stage="hear">
      <div class="pipeline-icon">🎵</div>
      <div class="pipeline-info">
        <span class="pipeline-name">Hear a song</span>
        <span class="pipeline-detail">Discover something worth keeping</span>
      </div>
    </div>
    <div class="pipeline-arrow">↓</div>

    <div class="pipeline-stage" data-stage="save">
      <div class="pipeline-icon">⌨</div>
      <div class="pipeline-info">
        <span class="pipeline-name">⌘ + Shift + S</span>
        <span class="pipeline-detail">Hotkey saves current track to Liked Songs instantly</span>
      </div>
    </div>
    <div class="pipeline-arrow">↓</div>

    <div class="pipeline-stage" data-stage="daily">
      <div class="pipeline-icon">♡</div>
      <div class="pipeline-info">
        <span class="pipeline-name">Daily Likes</span>
        <span class="pipeline-detail">Cron job at 11:30pm sweeps new liked songs into staging</span>
      </div>
    </div>
    <div class="pipeline-arrow">↓</div>

    <div class="pipeline-stage" data-stage="staging">
      <div class="pipeline-icon">📥</div>
      <div class="pipeline-info">
        <span class="pipeline-name">"New" playlist</span>
        <span class="pipeline-detail">Universal inbox — every automation reads from here</span>
      </div>
    </div>
    <div class="pipeline-arrow pipeline-branch-arrow">↓</div>

    <div class="pipeline-branch">
      <div class="pipeline-stage pipeline-small" data-stage="artist">
        <div class="pipeline-info">
          <span class="pipeline-name">Artist Match</span>
          <span class="pipeline-detail">100% confidence — artist only appears in one playlist</span>
        </div>
      </div>
      <div class="pipeline-stage pipeline-small" data-stage="genre">
        <div class="pipeline-info">
          <span class="pipeline-name">Genre Classifier</span>
          <span class="pipeline-detail">Spotify genres + audio features → folder match</span>
        </div>
      </div>
      <div class="pipeline-stage pipeline-small" data-stage="unclassified">
        <div class="pipeline-info">
          <span class="pipeline-name">Manual</span>
          <span class="pipeline-detail">Unclassified → I sort it myself</span>
        </div>
      </div>
    </div>
    <div class="pipeline-arrow">↓</div>

    <div class="pipeline-stage" data-stage="flow">
      <div class="pipeline-icon">⬆</div>
      <div class="pipeline-info">
        <span class="pipeline-name">Flow Characters</span>
        <span class="pipeline-detail">Songs cascade upward through the hierarchy via symbols in playlist names</span>
      </div>
    </div>
  </div>
</section>

<!-- The Flow System -->
<section class="music-section">
  <h2 class="music-section-title text-scramble" data-text="The Flow Alphabet" data-delay="200" data-always="false">The Flow Alphabet</h2>
  <p class="music-section-desc">Alchemical symbols embedded in playlist names encode parent-child relationships. No database, no config — the hierarchy lives in the names themselves.</p>

  <div class="flow-explainer">
    <div class="flow-rule">
      <span class="flow-rule-symbol">🜍 Name</span>
      <span class="flow-rule-arrow">→</span>
      <span class="flow-rule-meaning">Parent — receives songs</span>
    </div>
    <div class="flow-rule">
      <span class="flow-rule-symbol">Name 🜍</span>
      <span class="flow-rule-arrow">→</span>
      <span class="flow-rule-meaning">Child — sends songs up</span>
    </div>
    <div class="flow-rule">
      <span class="flow-rule-symbol">🜍 Name 🜁</span>
      <span class="flow-rule-arrow">→</span>
      <span class="flow-rule-meaning">Receives 🜍, sends to 🜁</span>
    </div>
  </div>

  <div class="flow-example">
    <div class="flow-example-chain">
      <span class="flow-node flow-child">Funk up my Soul 🜻</span>
      <span class="flow-cascade">→</span>
      <span class="flow-node flow-parent">🜻 Chef Up</span>
    </div>
    <p class="flow-example-desc">Songs added to "Funk up my Soul" automatically appear in "Chef Up"</p>
  </div>

  <div class="alphabet-grid" id="alphabet-grid">
    <div class="alphabet-card" data-symbol="🜍" style="--accent: #f59e0b;">
      <span class="alphabet-symbol">🜍</span>
      <span class="alphabet-genre">House</span>
    </div>
    <div class="alphabet-card" data-symbol="🜄" style="--accent: #06b6d4;">
      <span class="alphabet-symbol">🜄</span>
      <span class="alphabet-genre">Electronic</span>
    </div>
    <div class="alphabet-card" data-symbol="🜁" style="--accent: #8b5cf6;">
      <span class="alphabet-symbol">🜁</span>
      <span class="alphabet-genre">Bass</span>
    </div>
    <div class="alphabet-card" data-symbol="🜂" style="--accent: #ef4444;">
      <span class="alphabet-symbol">🜂</span>
      <span class="alphabet-genre">Rave</span>
    </div>
    <div class="alphabet-card" data-symbol="🜶" style="--accent: #22c55e;">
      <span class="alphabet-symbol">🜶</span>
      <span class="alphabet-genre">Alive</span>
    </div>
    <div class="alphabet-card" data-symbol="🜃" style="--accent: #6366f1;">
      <span class="alphabet-symbol">🜃</span>
      <span class="alphabet-genre">DnB / Sub</span>
    </div>
    <div class="alphabet-card" data-symbol="⏣" style="--accent: #a855f7;">
      <span class="alphabet-symbol">⏣</span>
      <span class="alphabet-genre">Cross-genre</span>
    </div>
    <div class="alphabet-card" data-symbol="🜔" style="--accent: #64748b;">
      <span class="alphabet-symbol">🜔</span>
      <span class="alphabet-genre">Chill</span>
    </div>
    <div class="alphabet-card" data-symbol="🜻" style="--accent: #eab308;">
