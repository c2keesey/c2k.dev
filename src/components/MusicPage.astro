  <p class="music-section-desc">Python automations running on cron, keeping everything in sync.</p>

  <div class="auto-grid">
    <div class="auto-card">
      <div class="auto-header">
        <span class="auto-name">save_current</span>
        <span class="auto-trigger">hotkey</span>
      </div>
      <p class="auto-desc">⌘+Shift+S saves the currently playing track to Liked Songs. Instant macOS notification.</p>
    </div>
    <div class="auto-card">
      <div class="auto-header">
        <span class="auto-name">daily_likes</span>
        <span class="auto-trigger">cron · 11:30pm</span>
      </div>
      <p class="auto-desc">Sweeps new liked songs into the "New" staging playlist. Tracks timestamps to never miss a song.</p>
    </div>
    <div class="auto-card">
      <div class="auto-header">
        <span class="auto-name">staging_classification</span>
        <span class="auto-trigger">on demand</span>
      </div>
      <p class="auto-desc">Processes "New" with a waterfall classifier: artist uniqueness match → genre classification → unclassified bucket.</p>
    </div>
    <div class="auto-card">
      <div class="auto-header">
        <span class="auto-name">playlist_flow</span>
        <span class="auto-trigger">cron · 9am</span>
      </div>
      <p class="auto-desc">Parses flow characters from playlist names, cascades songs upward through the hierarchy. Handles cycles, multi-hop chains.</p>
    </div>
    <div class="auto-card">
      <div class="auto-header">
        <span class="auto-name">folder_sorter</span>
        <span class="auto-trigger">on demand</span>
      </div>
      <p class="auto-desc">Routes songs into 「folder」 aggregator playlists based on artist history across the genre folder.</p>
    </div>
    <div class="auto-card">
      <div class="auto-header">
        <span class="auto-name">playlist_sync</span>
        <span class="auto-trigger">manual</span>
      </div>
      <p class="auto-desc">Mirrors Spotify playlists to local ~/Music for DJ sets. Bidirectional metadata sync.</p>
    </div>
  </div>

  <div class="auto-stack">
    <span class="auto-tech">Python</span>
    <span class="auto-tech">Spotipy</span>
    <span class="auto-tech">cron</span>
    <span class="auto-tech">LaunchAgents</span>
    <span class="auto-tech">Telegram</span>
  </div>

  <div class="auto-footer">
    <span class="auto-pre-llm">hand-written · 2024 · pre-LLM</span>
    <a class="auto-link" href="https://github.com/c2keesey/spotify-macro" target="_blank" rel="noopener">github.com/c2keesey/spotify-macro ↗</a>
  </div>
</section>

<script>
  // Genre grid accordion
  function initGenreGrid() {
    const cards = document.querySelectorAll<HTMLElement>('.genre-card');
    let activeGenre: string | null = null;

    cards.forEach(card => {
      card.addEventListener('click', () => {
        const genre = card.dataset.genre;
        if (!genre) return;

        const detail = document.getElementById(`genre-${genre}`);
        if (!detail) return;

        if (activeGenre === genre) {
          detail.classList.remove('genre-open');
          card.classList.remove('genre-active');
          card.querySelector('.genre-expand-icon')!.textContent = '+';
          activeGenre = null;
        } else {
          // Close previous
          if (activeGenre) {
            const prev = document.getElementById(`genre-${activeGenre}`);
            prev?.classList.remove('genre-open');
            cards.forEach(c => {
              c.classList.remove('genre-active');
              const icon = c.querySelector('.genre-expand-icon');
              if (icon) icon.textContent = '+';
            });
          }
          detail.classList.add('genre-open');
          card.classList.add('genre-active');
          card.querySelector('.genre-expand-icon')!.textContent = '−';
          activeGenre = genre;
        }
      });
    });
  }

  // Flow visualization canvas
  function initFlowViz() {
    const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = window.devicePixelRatio || 1;
    const w = canvas.offsetWidth;
    const h = canvas.offsetHeight;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    ctx.scale(dpr, dpr);

    // Flow tree: parent at top, children at bottom
    interface FlowNode {
      x: number; y: number; label: string; symbol: string; color: string; isParent: boolean;
    }

    interface FlowParticle {
      fromIdx: number; toIdx: number; progress: number; speed: number; color: string;
    }

    const nodes: FlowNode[] = [
      // Parent (top center)
      { x: w * 0.5, y: 28, label: '🜍 H', symbol: '🜍', color: '#f59e0b', isParent: true },
      // Children (bottom row)
      { x: w * 0.12, y: h - 20, label: 'CRANK 🜍🜂', symbol: '🜍', color: '#f59e0b', isParent: false },
      { x: w * 0.32, y: h - 20, label: 'Bump Beats 🜍', symbol: '🜍', color: '#f59e0b', isParent: false },
      { x: w * 0.52, y: h - 20, label: 'All night 🜍', symbol: '🜍', color: '#f59e0b', isParent: false },
      { x: w * 0.72, y: h - 20, label: 'Poolside 🜍', symbol: '🜍', color: '#f59e0b', isParent: false },
      { x: w * 0.92, y: h - 20, label: 'Summer 🜍', symbol: '🜍', color: '#f59e0b', isParent: false },
    ];

    let particles: FlowParticle[] = [];
    let lastSpawn = 0;

    function draw(time: number) {
      ctx.clearRect(0, 0, w, h);

      // Draw connection lines (children to parent)
      for (let i = 1; i < nodes.length; i++) {
        const child = nodes[i];
        const parent = nodes[0];
        ctx.beginPath();
        ctx.moveTo(child.x, child.y);
        // Bezier curve upward
        const cpY = (child.y + parent.y) / 2;
        ctx.quadraticCurveTo(child.x, cpY, parent.x, parent.y);
        ctx.strokeStyle = 'rgba(245, 158, 11, 0.1)';
        ctx.lineWidth = 1;
        ctx.stroke();
      }

      // Spawn particles
      if (time - lastSpawn > 800) {
        const fromIdx = 1 + Math.floor(Math.random() * (nodes.length - 1));
        particles.push({
          fromIdx,
          toIdx: 0,
          progress: 0,
          speed: 0.006 + Math.random() * 0.004,
          color: nodes[fromIdx].color,
        });
        lastSpawn = time;
      }

      // Draw and update particles
      particles = particles.filter(p => {
        p.progress += p.speed;
        if (p.progress >= 1) return false;

        const from = nodes[p.fromIdx];
        const to = nodes[p.toIdx];
        const t = p.progress;
        const cpY = (from.y + to.y) / 2;

        // Quadratic bezier point
        const mt = 1 - t;
        const px = mt * mt * from.x + 2 * mt * t * from.x + t * t * to.x;
        const py = mt * mt * from.y + 2 * mt * t * cpY + t * t * to.y;
        const alpha = Math.sin(t * Math.PI);

        // Glow
        ctx.beginPath();
        ctx.arc(px, py, 6, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(245, 158, 11, ${alpha * 0.15})`;
        ctx.fill();

        // Core
        ctx.beginPath();
        ctx.arc(px, py, 2.5, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(245, 158, 11, ${alpha * 0.9})`;
        ctx.fill();

        return true;
      });

      // Draw node labels
      ctx.font = '9px "JetBrains Mono", monospace';
      ctx.textAlign = 'center';
      nodes.forEach(node => {
        ctx.fillStyle = node.isParent ? 'rgba(245, 158, 11, 0.9)' : 'rgba(255, 255, 255, 0.45)';
        ctx.fillText(node.label, node.x, node.y + (node.isParent ? 4 : -2));
      });

      requestAnimationFrame(draw);
    }

    // Only run when visible
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          requestAnimationFrame(draw);
          observer.disconnect();
        }
      });
    }, { threshold: 0.2 });

    const viz = document.getElementById('flow-viz');
    if (viz) observer.observe(viz);
  }

  // Pipeline stage hover
  function initPipeline() {
    const stages = document.querySelectorAll<HTMLElement>('.pipeline-stage');
    stages.forEach((stage, i) => {
      stage.style.animationDelay = `${i * 100}ms`;
    });
  }

  initGenreGrid();
  initFlowViz();
  initPipeline();
</script>

