---
import TextScramble from '../components/TextScramble.astro';
import Nav from '../components/Nav.astro';
import DotfilesShowcase from '../components/DotfilesShowcase.astro';
import MaiaShowcase from '../components/MaiaShowcase.astro';
import C2kShowcase from '../components/C2kShowcase.astro';
import LightningCloudShowcase from '../components/LightningCloudShowcase.astro';
import FluxGauntletShowcase from '../components/FluxGauntletShowcase.astro';
import CorneShowcase from '../components/CorneShowcase.astro';
import SpotifyMacroShowcase from '../components/SpotifyMacroShowcase.astro';
import MiniProjectCard from '../components/MiniProjectCard.astro';
import RotatingQuote from '../components/RotatingQuote.astro';
import DesktopDashboard from '../components/DesktopDashboard.astro';
import MobileNetworkView from '../components/MobileNetworkView.astro';
import BlogDesktop from '../components/BlogDesktop.astro';
import BlogMobile from '../components/BlogMobile.astro';
import FeatureLabPage from '../components/FeatureLabPage.astro';
const showFeatureLab = !!process.env.FEATURE_LAB;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#7c3aed" />
    <title>C2K</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://api.fontshare.com/v2/css?f[]=satoshi@500,600,700,800&display=swap" rel="stylesheet" />
    <script is:inline>
      // FOUC prevention: apply theme before first paint
      (function() {
        var t = localStorage.getItem('c2k-theme');
        if (t && t !== 'dark') document.documentElement.dataset.theme = t;
      })();
    </script>
  </head>
  <body>
    <Nav showLab={showFeatureLab} />

    <div class="swipe-container" id="swipe-container">
      <!-- Panel: Home -->
      <section class="swipe-panel" data-page="/">
        <div class="panel-content">
          <section class="hero">
            <div class="hero-title-wrapper">
              <h1 class="hero-title" id="hero-title">–––</h1>
            </div>
            <div class="bio">
              <p class="bio-role">
                <TextScramble text="CTO, context engineer " tag="span" delay={150} />
                <a href="https://maia-analytics.com" class="text-scramble" data-text="@maia_analytics" data-delay="150" data-always="false" target="_blank" rel="noopener">@maia_analytics</a>
              </p>
              <TextScramble text="Outer Sunset, SF · Ridiculous output · Living in agreement with nature" tag="p" class="bio-tagline" delay={250} />
              <div class="bio-links">
                <a href="https://github.com/c2keesey" class="text-scramble" data-text="github" data-delay="350" data-always="false" target="_blank" rel="noopener">github</a>
                <a href="https://x.com/c2keesey" class="text-scramble" data-text="x" data-delay="350" data-always="false" target="_blank" rel="noopener">x</a>
                <a href="https://linkedin.com/in/c2keesey" class="text-scramble" data-text="linkedin" data-delay="350" data-always="false" target="_blank" rel="noopener">linkedin</a>
              </div>
            </div>
            <RotatingQuote />
          </section>

          <div class="home-grid">
            <div class="home-grid-left">
              <div class="building-section" id="building-section">
                <div class="building-header">
                  <span class="building-pulse"></span>
                  <span class="building-label">currently building</span>
                </div>
                <div class="building-repos" id="building-repos"></div>
              </div>

              <div class="systems-widget" id="systems-widget">
                <div class="systems-header">
                  <span class="systems-dot"></span>
                  <span class="systems-label">systems</span>
                </div>
                <div class="systems-body" id="systems-body">
                  <div class="systems-stat">
                    <span class="systems-stat-val" id="sys-services">--</span>
                    <span class="systems-stat-key">services</span>
                  </div>
                  <div class="systems-stat">
                    <span class="systems-stat-val" id="sys-crons">--</span>
                    <span class="systems-stat-key">crons</span>
                  </div>
                  <div class="systems-stat">
                    <span class="systems-stat-val" id="sys-cpu">--%</span>
                    <span class="systems-stat-key">cpu</span>
                  </div>
                  <div class="systems-stat">
                    <span class="systems-stat-val" id="sys-mem">--%</span>
                    <span class="systems-stat-key">mem</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="home-grid-right">
              <MaiaShowcase />
            </div>
          </div>
        </div>
      </section>

      <!-- Panel: Projects -->
      <section class="swipe-panel" data-page="/projects">
        <!-- Desktop: spatial dashboard layout -->
        <DesktopDashboard />
        <!-- Mobile: network card stack -->
        <MobileNetworkView />
        <!-- Showcase components (hidden, moved into focus overlays on demand) -->
        <div class="showcases-source">
          <MaiaShowcase />
          <C2kShowcase />
          <FluxGauntletShowcase />
          <CorneShowcase />
          <SpotifyMacroShowcase />
          <MiniProjectCard
            name="optiplex-dashboard"
            tagline="Server monitoring PWA"
            description="Mobile-first dashboard for the Optiplex. CPU, memory, disk, network sparklines, cron job status, Claude sessions — all polled live. Installable PWA over Tailscale."
            badge="infra"
            tech={['Next.js', 'TypeScript', 'shadcn/ui', 'SQLite', 'systeminformation']}
            accentColor="224, 122, 95"
          />
          <DotfilesShowcase />
          <MiniProjectCard
            name="secret-gate"
            tagline="Human-in-the-loop approval gate"
            description="Routes AI agent requests for secrets (1Password) and sudo commands through Telegram for explicit approval. Ships as a Claude Code plugin with PreToolUse hooks."
            badge="security"
            wip={true}
            tech={['Python', '1Password CLI', 'Telegram', 'Claude Code Plugin']}
            link="https://github.com/c2keesey/secret-gate"
            linkText="github.com/c2keesey/secret-gate"
            accentColor="239, 68, 68"
          />
          <MiniProjectCard
            name="tech-digest"
            tagline="Daily tech release digest via Telegram"
            description="Fetches release notes from GitHub repos and web changelogs (Claude Code, Cursor, Linear, etc.), parses them with Claude CLI, and sends formatted summaries via Telegram. Includes a Telegram bot for remote repo control through a headless Claude Code session."
            badge="daily driver"
            tech={['Python', 'Claude CLI', 'Telegram', 'GitHub API', 'cron']}
            link="https://github.com/c2keesey/tech-digest"
            linkText="github.com/c2keesey/tech-digest"
            accentColor="139, 92, 246"
          />
          <MiniProjectCard
            name="morning-digest"
            tagline="LLM-powered personal news briefing"
            description="Fetches RSS from 9 sources across world news, SF local, and tech. Claude Haiku generates two-tier summaries — quick scans on fetch, deep dives on tap. Self-hosted Next.js PWA served over Tailscale."
            badge="daily driver"
            tech={['Next.js', 'TypeScript', 'Claude Haiku', 'SQLite', 'Tailwind', 'RSS']}
            accentColor="56, 189, 248"
          />
          <LightningCloudShowcase />
          <MiniProjectCard
            name="propeller-scrape"
            tagline="Concert ticket monitor"
            description="Scrapes Propeller rewards for new concert tickets in LA, SF, and Boulder. Sends Telegram notifications when shows appear. Runs on cron."
            badge="utility"
            tech={['Python', 'BeautifulSoup', 'Telegram', 'cron']}
            link="https://github.com/c2keesey/propeller-scrape"
            linkText="github.com/c2keesey/propeller-scrape"
            accentColor="249, 115, 22"
          />
        </div>
      </section>

      <!-- Panel: Log (Blog) -->
      <section class="swipe-panel" data-page="/log">
        <BlogDesktop />
        <BlogMobile />
      </section>

      <!-- Panel: About -->
      <section class="swipe-panel" data-page="/about">
        <div class="panel-content">
          <section class="page-header">
            <TextScramble text="About" tag="h1" class="page-title" always />
          </section>

          <div class="about-grid">
            <div class="about-grid-left">
              <!-- Fastfetch-style readout -->
              <div class="about-fetch">
                <div class="fetch-block">
                  <div class="fetch-row">
                    <span class="fetch-key">name</span>
                    <span class="fetch-val text-scramble" data-text="Christopher Keesey" data-delay="100" data-always="false">Christopher Keesey</span>
                  </div>
                  <div class="fetch-row">
                    <span class="fetch-key">handle</span>
                    <span class="fetch-val text-scramble" data-text="C2K" data-delay="150" data-always="false">C2K</span>
                  </div>
                  <div class="fetch-row">
                    <span class="fetch-key">role</span>
                    <span class="fetch-val text-scramble" data-text="CTO · context engineer" data-delay="200" data-always="false">CTO · context engineer</span>
                  </div>
                  <div class="fetch-row">
                    <span class="fetch-key">company</span>
                    <span class="fetch-val"><a href="https://maia-analytics.com" class="fetch-link text-scramble" data-text="MAIA Analytics" data-delay="250" data-always="false" target="_blank" rel="noopener">MAIA Analytics</a></span>
                  </div>
                  <div class="fetch-row">
                    <span class="fetch-key">location</span>
                    <span class="fetch-val text-scramble" data-text="Outer Sunset, SF" data-delay="300" data-always="false">Outer Sunset, SF</span>
                  </div>
                </div>

                <div class="fetch-divider"></div>

                <div class="fetch-block">
                  <div class="fetch-row">
                    <span class="fetch-key">editor</span>
                    <span class="fetch-val">Claude Code</span>
                  </div>
                  <div class="fetch-row">
                    <span class="fetch-key">terminal</span>
                    <span class="fetch-val">Ghostty + Tmux</span>
                  </div>
                  <div class="fetch-row">
                    <span class="fetch-key">keyboard</span>
                    <span class="fetch-val">Corne 42-key split</span>
                  </div>
                  <div class="fetch-row">
                    <span class="fetch-key">host</span>
                    <span class="fetch-val">OptiPlex micro · Ubuntu</span>
                  </div>
                  <div class="fetch-row">
                    <span class="fetch-key">network</span>
                    <span class="fetch-val">Tailscale + Cloudflare Tunnel</span>
                  </div>
                  <div class="fetch-row">
                    <span class="fetch-key">whip</span>
                    <span class="fetch-val">Maroon Honda Odyssey</span>
                  </div>
                </div>

                <div class="fetch-divider"></div>

                <div class="fetch-block">
                  <div class="fetch-row">
                    <span class="fetch-key">languages</span>
                    <span class="fetch-val">Natural Language · TypeScript · Python · Go</span>
                  </div>
                  <div class="fetch-row">
                    <span class="fetch-key">frontend</span>
                    <span class="fetch-val">React · Astro · Tailwind</span>
                  </div>
                  <div class="fetch-row">
                    <span class="fetch-key">backend</span>
                    <span class="fetch-val">FastAPI · Node · Postgres</span>
                  </div>
                  <div class="fetch-row">
                    <span class="fetch-key">infra</span>
                    <span class="fetch-val">GCP · Docker · systemd · Cloudflare</span>
                  </div>
                  <div class="fetch-row">
                    <span class="fetch-key">ai</span>
                    <span class="fetch-val">Claude Code · MCP · Pydantic AI</span>
                  </div>
                </div>

                <div class="fetch-colors" id="fetch-colors">
                  <button class="fetch-swatch" style="background: #a855f7;" data-hex="#a855f7" data-name="purple" aria-label="Purple #a855f7"></button>
                  <button class="fetch-swatch" style="background: #f97316;" data-hex="#f97316" data-name="orange" aria-label="Orange #f97316"></button>
                  <button class="fetch-swatch" style="background: #22c55e;" data-hex="#22c55e" data-name="green" aria-label="Green #22c55e"></button>
                  <button class="fetch-swatch" style="background: #3b82f6;" data-hex="#3b82f6" data-name="blue" aria-label="Blue #3b82f6"></button>
                  <button class="fetch-swatch" style="background: #ef4444;" data-hex="#ef4444" data-name="red" aria-label="Red #ef4444"></button>
                  <button class="fetch-swatch" style="background: #eab308;" data-hex="#eab308" data-name="yellow" aria-label="Yellow #eab308"></button>
                  <button class="fetch-swatch" style="background: #06b6d4;" data-hex="#06b6d4" data-name="cyan" aria-label="Cyan #06b6d4"></button>
                  <button class="fetch-swatch" style="background: #e4e4e7;" data-hex="#e4e4e7" data-name="zinc" aria-label="Zinc #e4e4e7"></button>
                </div>
              </div>
            </div>

            <div class="about-grid-right">
              <div class="about-blurb">
                <p>I'm Christopher Keesey — C2K. I'm building MAIA Analytics, an AI-native geospatial platform where you ask questions and get maps. Day to day that means LLM orchestration, agentic workflows, and a lot of property data pipelines — TypeScript, Python, FastAPI, Postgres, Claude Code. I care about simple code, minimal abstraction, and shipping.</p>
                <p>When I'm not building, I'm surfing the Outer Sunset, skiing backcountry, or mixing dubstep and drum & bass. I solder things that don't need to exist — LED gauntlets, lightning clouds, split keyboards. Everything I use is version-controlled, self-hosted where it matters, and accessible from anywhere. This site is the public layer of that system.</p>
              </div>

              <div class="about-links">
                <a href="https://github.com/c2keesey" class="about-link-card" target="_blank" rel="noopener">
                  <span class="about-link-name">GitHub</span>
                  <span class="about-link-handle">c2keesey</span>
                </a>
                <a href="https://x.com/c2keesey" class="about-link-card" target="_blank" rel="noopener">
                  <span class="about-link-name">X</span>
                  <span class="about-link-handle">c2keesey</span>
                </a>
                <a href="https://linkedin.com/in/c2keesey" class="about-link-card" target="_blank" rel="noopener">
                  <span class="about-link-name">LinkedIn</span>
                  <span class="about-link-handle">c2keesey</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      {showFeatureLab && (
        <section class="swipe-panel" data-page="/lab">
          <div class="panel-content">
            <FeatureLabPage />
          </div>
        </section>
      )}
    </div>
    <footer class="global-footer">
      <div class="status-row">
        <span class="status-dot connecting" id="status-dot"></span>
        <span class="status-text" id="status-text">AWAITING TELEMETRY</span>
      </div>
    </footer>
  </body>
</html>

<script>
  // Hero scramble: decode "CHRISTOPHER CARSON KEESEY"
  (function heroScramble() {
    const el = document.getElementById('hero-title');
    if (!el) return;

    const chars = '0123456789ABCDEF~!@#$%^&*()+=_';
    const name = 'CHRISTOPHER CARSON KEESEY';
    const duration = 900;

    el.textContent = name.replace(/[^ ]/g, '–');

    const birth: number[] = [];
    const resolve: number[] = [];
    const bw = duration * 0.3;
    const rw = duration * 0.7;
    for (let i = 0; i < name.length; i++) {
      const bias = (i / name.length) * bw * 0.5;
      birth[i] = bias + Math.random() * bw * 0.5;
      resolve[i] = bw + bias + Math.random() * rw * 0.4;
    }

    let start: number | null = null;
    function step(ts: number) {
      if (!start) start = ts;
      const elapsed = ts - start;
      if (elapsed < duration) {
        el.textContent = '';
        const frag = document.createDocumentFragment();
        for (let i = 0; i < name.length; i++) {
          if (name[i] === ' ') {
            frag.appendChild(document.createTextNode(' '));
          } else if (elapsed >= resolve[i]) {
            frag.appendChild(document.createTextNode(name[i]));
          } else if (elapsed >= birth[i]) {
            const span = document.createElement('span');
            span.className = 'scramble-glyph';
            span.textContent = chars[Math.floor(Math.random() * chars.length)];
            frag.appendChild(span);
          } else {
            const span = document.createElement('span');
            span.className = 'scramble-idle';
            span.textContent = '–';
            frag.appendChild(span);
          }
        }
        el.appendChild(frag);
        requestAnimationFrame(step);
      } else {
        el.textContent = name;
      }
    }
    requestAnimationFrame(step);
  })();

  const container = document.getElementById('swipe-container')!
  const pages = ['/', '/projects', '/log', '/about'];

  // Scroll to correct panel on load based on URL
  function scrollToCurrentPage() {
    const path = location.pathname;
    const index = pages.findIndex(p =>
      p === '/' ? path === '/' || path === '' : path.startsWith(p)
    );
    if (index > 0) {
      container.scrollTo({ left: index * container.clientWidth, behavior: 'instant' });
    }
  }

  scrollToCurrentPage();

  // Track active panel for re-triggering animations
  const initialIndex = pages.findIndex(p =>
    p === '/' ? location.pathname === '/' || location.pathname === '' : location.pathname.startsWith(p)
  );
  let lastActiveIndex = Math.max(0, initialIndex);

  // Update URL as user swipes
  let scrollTimeout: ReturnType<typeof setTimeout>;
  container.addEventListener('scroll', () => {
    const panelWidth = container.clientWidth;
    const progress = container.scrollLeft / panelWidth;
    const activeIndex = Math.round(progress);

    // Update nav indicator position (smooth tracking)
    updateNavIndicator(progress);

    // Debounce URL update until scroll settles
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(() => {
      const newPath = pages[activeIndex];
      if (newPath && location.pathname !== newPath) {
        history.replaceState(null, '', newPath);
      }

      // Re-trigger scramble animations when landing on a new panel
      if (activeIndex !== lastActiveIndex) {
        lastActiveIndex = activeIndex;
        const panels = container.querySelectorAll('.swipe-panel');
        panels[activeIndex]?.querySelectorAll('.text-scramble').forEach(el => {
          el.dispatchEvent(new Event('scramble:trigger'));
        });
        // Sync mobile bottom nav
        window.dispatchEvent(new CustomEvent('nav:update', { detail: { index: activeIndex } }));
      }
    }, 100);
  }, { passive: true });

  // Nav indicator tracking
  function updateNavIndicator(progress: number) {
    const navContainer = document.getElementById('nav-links');
    const indicator = document.getElementById('nav-indicator');
    const links = navContainer?.querySelectorAll<HTMLAnchorElement>('.nav-link');
    if (!navContainer || !indicator || !links || links.length === 0) return;

    const fromIndex = Math.max(0, Math.min(Math.floor(progress), links.length - 1));
    const toIndex = Math.min(fromIndex + 1, links.length - 1);
    const fraction = progress - fromIndex;

    const containerRect = navContainer.getBoundingClientRect();
    const fromRect = links[fromIndex].getBoundingClientRect();
    const toRect = links[toIndex].getBoundingClientRect();

    const fromX = fromRect.left - containerRect.left;
    const toX = toRect.left - containerRect.left;
    const x = fromX + (toX - fromX) * fraction;
    const width = fromRect.width + (toRect.width - fromRect.width) * fraction;

    indicator.style.transition = 'none';
    indicator.style.width = `${width}px`;
    indicator.style.transform = `translateX(${x}px)`;
    indicator.style.opacity = '1';
  }

  // Handle nav click -> scroll to panel
  const isDesktop = () => window.matchMedia('(min-width: 768px)').matches;

  function navigateToPanel(index: number) {
    container.scrollTo({
      left: index * container.clientWidth,
      behavior: isDesktop() ? 'instant' : 'smooth',
    });

    // On desktop, scrollTo with instant + overflow hidden may not fire scroll event
    // so manually handle URL + animation re-trigger
    if (isDesktop()) {
      const newPath = pages[index];
      if (newPath && location.pathname !== newPath) {
        history.replaceState(null, '', newPath);
      }
      updateNavIndicator(index);
      if (index !== lastActiveIndex) {
        lastActiveIndex = index;
        const panels = container.querySelectorAll('.swipe-panel');
        panels[index]?.querySelectorAll('.text-scramble').forEach(el => {
          el.dispatchEvent(new Event('scramble:trigger'));
        });
        // Sync mobile bottom nav
        window.dispatchEvent(new CustomEvent('nav:update', { detail: { index } }));
      }
    }
  }

  // Logo: reload if already on home, otherwise navigate to home
  document.querySelector('.logo')?.addEventListener('click', (e) => {
    e.preventDefault();
    if (lastActiveIndex === 0) { window.location.href = '/'; } else { navigateToPanel(0); }
  });

  document.querySelectorAll<HTMLAnchorElement>('.nav-link').forEach((link, i) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      navigateToPanel(i);
    });
  });

  // Mobile bottom nav: listen for tab clicks
  window.addEventListener('nav:goto', ((e: CustomEvent) => {
    navigateToPanel(e.detail.index);
  }) as EventListener);

  // Position indicator on load after fonts
  document.fonts?.ready.then(() => {
    const path = location.pathname;
    const index = pages.findIndex(p =>
      p === '/' ? path === '/' || path === '' : path.startsWith(p)
    );
    updateNavIndicator(Math.max(0, index));
  });

  // Live status footer
  const statusDot = document.getElementById('status-dot')!;
  const statusText = document.getElementById('status-text')!;

  const STATUS_COLORS: Record<string, string> = {
    green: '#22c55e',
    yellow: '#eab308',
    red: '#ef4444',
    offline: '#6b7280',
  };

  function setStatusState(color: string, className: string) {
    statusDot.style.background = color;
    statusDot.className = 'status-dot ' + className;
  }

  // Scramble a stat value from noise into the real value
  function scrambleStat(el: HTMLElement, target: string, duration = 550) {
    const digits = '0123456789';
    const noise = '░▒╳·';
    function randomChar(c: string) {
      if (/[0-9]/.test(c)) return digits[Math.floor(Math.random() * digits.length)];
      if (c === '%' || c === '/') return c;
      return noise[Math.floor(Math.random() * noise.length)];
    }
    const start = Date.now();
    const len = target.length;
    function frame() {
      const elapsed = Date.now() - start;
      const progress = Math.min(elapsed / duration, 1);
      let result = '';
      for (let i = 0; i < len; i++) {
        const charProgress = Math.max(0, progress * 1.4 - (i / len) * 0.4);
        result += charProgress >= 1 ? target[i] : randomChar(target[i]);
      }
      el.textContent = result;
      if (progress < 1) requestAnimationFrame(frame);
      else el.textContent = target;
    }
    requestAnimationFrame(frame);
  }

  async function updateStatus() {
    try {
      const res = await fetch('/api/status');
      const data = await res.json();

      if (data.status === 'offline') {
        setStatusState(STATUS_COLORS.offline, 'offline');
        statusText.textContent = 'OPTIPLEX OFFLINE';
        return;
      }

      // Determine overall state label
      const hasErrors = data.overall === 'red';
      const hasWarnings = data.overall === 'yellow';

      if (hasErrors) {
        setStatusState(STATUS_COLORS.red, 'advisory');
      } else if (hasWarnings) {
        setStatusState(STATUS_COLORS.yellow, 'warning');
      } else {
        setStatusState(STATUS_COLORS.green, 'nominal');
      }

      // Build status segments with priority levels
      // Priority 1: state label (always shown)
      // Priority 2: services summary (shown when space allows)
      // Priority 3: vitals (shown on wider screens)
      const segments: { text: string; priority: number }[] = [];

      // State label — always first
      if (hasErrors) {
        segments.push({ text: 'ADVISORY', priority: 1 });
      } else if (hasWarnings) {
        segments.push({ text: 'STANDBY', priority: 1 });
      } else {
        segments.push({ text: 'OPERATIONAL', priority: 1 });
      }

      // Services summary
      if (data.services.running === data.services.total) {
        segments.push({ text: `${data.services.total} SERVICES`, priority: 2 });
      } else {
        segments.push({ text: `${data.services.running}/${data.services.total} SERVICES`, priority: 2 });
      }

      // Crons summary
      if (data.crons.error > 0) {
        segments.push({ text: `${data.crons.error} CRON FAULT`, priority: 2 });
      } else if (data.crons.ok === data.crons.total) {
        segments.push({ text: `${data.crons.total} CRONS`, priority: 3 });
      } else {
        segments.push({ text: `${data.crons.ok}/${data.crons.total} CRONS`, priority: 3 });
      }

      // System vitals
      if (data.cpu !== null) segments.push({ text: `CPU ${data.cpu}%`, priority: 3 });
      if (data.memory !== null) segments.push({ text: `MEM ${data.memory}%`, priority: 3 });
      if (data.uptime) segments.push({ text: data.uptime.toUpperCase(), priority: 4 });

      // Responsive: on narrow screens, only show higher-priority segments
      const isMobile = window.innerWidth < 640;
      const maxPriority = isMobile ? 2 : 4;
      const visibleSegments = segments.filter(s => s.priority <= maxPriority);

      statusText.textContent = visibleSegments.map(s => s.text).join(' \u00b7 ');

      // Populate systems widget
      const sysServices = document.getElementById('sys-services');
      const sysCrons = document.getElementById('sys-crons');
      const sysCpu = document.getElementById('sys-cpu');
      const sysMem = document.getElementById('sys-mem');
      if (sysServices) scrambleStat(sysServices, `${data.services.running}/${data.services.total}`);
      if (sysCrons) scrambleStat(sysCrons, `${data.crons.ok}/${data.crons.total}`);
      if (sysCpu) scrambleStat(sysCpu, data.cpu !== null ? `${data.cpu}%` : '--');
      if (sysMem) scrambleStat(sysMem, data.memory !== null ? `${data.memory}%` : '--');
    } catch {
      setStatusState(STATUS_COLORS.offline, 'offline');
      statusText.textContent = 'SIGNAL LOST';
    }
  }

  updateStatus();
  setInterval(updateStatus, 30000);

  // Dev shortcut: double-tap footer to reload
  let lastFooterTap = 0;
  document.querySelector('.global-footer')?.addEventListener('click', () => {
    const now = Date.now();
    if (now - lastFooterTap < 400) {
      window.location.href = '/' + location.hash;
    }
    lastFooterTap = now;
  });

  // Color swatch tooltips
  document.querySelectorAll<HTMLButtonElement>('.fetch-swatch').forEach(swatch => {
    const hex = swatch.dataset.hex || '';
    const name = swatch.dataset.name || '';

    const tooltip = document.createElement('div');
    tooltip.className = 'swatch-tooltip';
    tooltip.innerHTML = `<span class="swatch-hex">${hex}</span><span class="swatch-name">${name}</span>`;
    swatch.appendChild(tooltip);

    // Desktop: hover
    swatch.addEventListener('mouseenter', () => tooltip.classList.add('visible'));
    swatch.addEventListener('mouseleave', () => tooltip.classList.remove('visible'));

    // Mobile: tap to toggle, tap elsewhere to dismiss
    swatch.addEventListener('click', (e) => {
      e.stopPropagation();
      const wasVisible = tooltip.classList.contains('visible');
      // Close all other tooltips
      document.querySelectorAll('.swatch-tooltip.visible').forEach(t => t.classList.remove('visible'));
      if (!wasVisible) tooltip.classList.add('visible');
    });
  });

  document.addEventListener('click', () => {
    document.querySelectorAll('.swatch-tooltip.visible').forEach(t => t.classList.remove('visible'));
  });

  // Currently building
  const buildingRepos = document.getElementById('building-repos');
  const buildingSection = document.getElementById('building-section');

  function timeAgo(dateStr: string): string {
    const diff = Date.now() - new Date(dateStr).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return 'just now';
    if (mins < 60) return `${mins}m ago`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return `${hrs}h ago`;
    const days = Math.floor(hrs / 24);
    return `${days}d ago`;
  }

  if (buildingRepos) {
    fetch('/api/activity')
      .then(r => r.json())
      .then((data: { repos: Array<{ name: string; url: string; description: string; lastCommit: string; pushedAt: string }> }) => {
        if (data.repos.length === 0) {
          buildingSection?.remove();
          return;
        }
        data.repos.forEach((repo, i) => {
          const row = document.createElement('a');
          row.href = repo.url;
          row.target = '_blank';
          row.rel = 'noopener';
          row.className = 'building-row';
          row.style.animationDelay = `${i * 120}ms`;

          const dot = document.createElement('span');
          dot.className = 'building-dot';

          const info = document.createElement('span');
          info.className = 'building-info';

          const name = document.createElement('span');
          name.className = 'building-name';
          name.textContent = repo.name;

          const commit = document.createElement('span');
          commit.className = 'building-commit';
          commit.textContent = repo.lastCommit || repo.description || '';

          info.appendChild(name);
          if (commit.textContent) info.appendChild(commit);

          const time = document.createElement('span');
          time.className = 'building-time';
          time.textContent = repo.pushedAt ? timeAgo(repo.pushedAt) : '';

          row.appendChild(dot);
          row.appendChild(info);
          row.appendChild(time);
          buildingRepos.appendChild(row);
        });
      })
      .catch(() => buildingSection?.remove());
  }
</script>

