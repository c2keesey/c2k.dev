---
import TextScramble from '../components/TextScramble.astro';
import Nav from '../components/Nav.astro';
import StatuslineShowcase from '../components/StatuslineShowcase.astro';
import SkillsShowcase from '../components/SkillsShowcase.astro';
import MaiaShowcase from '../components/MaiaShowcase.astro';
import C2kShowcase from '../components/C2kShowcase.astro';
import BodegaWeekend from '../components/BodegaWeekend.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>c2k</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Nav />

    <div class="swipe-container" id="swipe-container">
      <!-- Panel: Home -->
      <section class="swipe-panel" data-page="/">
        <div class="panel-content">
          <section class="hero">
            <TextScramble text="c2k" tag="h1" class="hero-title" always />
            <div class="bio">
              <p class="bio-role">
                <TextScramble text="CTO, context engineer " tag="span" delay={150} />
                <a href="https://maia-analytics.com" class="text-scramble" data-text="@maia_analytics" data-delay="150" data-always="false" target="_blank" rel="noopener">@maia_analytics</a>
              </p>
              <TextScramble text="Outer Sunset, SF · Ridiculous output · Living in agreement with nature" tag="p" class="bio-tagline" delay={250} />
              <div class="bio-links">
                <a href="https://github.com/c2keesey" class="text-scramble" data-text="github" data-delay="350" data-always="false" target="_blank" rel="noopener">github</a>
                <a href="https://x.com/c2keesey" class="text-scramble" data-text="x" data-delay="350" data-always="false" target="_blank" rel="noopener">x</a>
                <a href="https://linkedin.com/in/c2keesey" class="text-scramble" data-text="linkedin" data-delay="350" data-always="false" target="_blank" rel="noopener">linkedin</a>
              </div>
            </div>
          </section>

          <div class="building-section" id="building-section">
            <div class="building-header">
              <span class="building-pulse"></span>
              <span class="building-label">currently building</span>
            </div>
            <div class="building-repos" id="building-repos"></div>
          </div>

          <MaiaShowcase />
        </div>
      </section>

      <!-- Panel: Projects -->
      <section class="swipe-panel" data-page="/projects">
        <div class="panel-content">
          <section class="page-header">
            <TextScramble text="Projects" tag="h1" class="page-title" always />
            <TextScramble text="Things I'm building." tag="p" class="page-desc" delay={100} />
          </section>
          <C2kShowcase />
          <StatuslineShowcase />
          <SkillsShowcase />
        </div>
      </section>

      <!-- Panel: About -->
      <section class="swipe-panel" data-page="/about">
        <div class="panel-content">
          <section class="page-header">
            <TextScramble text="About" tag="h1" class="page-title" always />
          </section>
          <div class="about-content">
            <TextScramble text="Developer running a personal VM as a second brain. Everything orchestrated through Claude Code, tracked with beads, accessed from anywhere via Tailscale and Terminus." tag="p" delay={100} />
            <TextScramble text="This site is the public layer of that system." tag="p" delay={250} />
          </div>
        </div>
      </section>

      <!-- Panel: Bodega -->
      <section class="swipe-panel" data-page="/bodega">
        <div class="panel-content">
          <section class="page-header">
            <TextScramble text="Bodega Weekend" tag="h1" class="page-title" always />
            <TextScramble text="Goat ranch, bike ride, crab shack, sunset." tag="p" class="page-desc" delay={100} />
          </section>
          <BodegaWeekend />
        </div>
      </section>
    </div>
    <footer class="global-footer">
      <div class="status-row">
        <span class="status-dot" id="status-dot"></span>
        <span class="status-text" id="status-text">connecting...</span>
      </div>
    </footer>
  </body>
</html>

<script>
  const container = document.getElementById('swipe-container')!;
  const pages = ['/', '/projects', '/about', '/bodega'];

  // Scroll to correct panel on load based on URL
  function scrollToCurrentPage() {
    const path = location.pathname;
    const index = pages.findIndex(p =>
      p === '/' ? path === '/' || path === '' : path.startsWith(p)
    );
    if (index > 0) {
      container.scrollTo({ left: index * container.clientWidth, behavior: 'instant' });
    }
  }

  scrollToCurrentPage();

  // Track active panel for re-triggering animations
  const initialIndex = pages.findIndex(p =>
    p === '/' ? location.pathname === '/' || location.pathname === '' : location.pathname.startsWith(p)
  );
  let lastActiveIndex = Math.max(0, initialIndex);

  // Update URL as user swipes
  let scrollTimeout: ReturnType<typeof setTimeout>;
  container.addEventListener('scroll', () => {
    const panelWidth = container.clientWidth;
    const progress = container.scrollLeft / panelWidth;
    const activeIndex = Math.round(progress);

    // Update nav indicator position (smooth tracking)
    updateNavIndicator(progress);

    // Debounce URL update until scroll settles
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(() => {
      const newPath = pages[activeIndex];
      if (newPath && location.pathname !== newPath) {
        history.replaceState(null, '', newPath);
      }

      // Re-trigger scramble animations when landing on a new panel
      if (activeIndex !== lastActiveIndex) {
        lastActiveIndex = activeIndex;
        const panels = container.querySelectorAll('.swipe-panel');
        panels[activeIndex]?.querySelectorAll('.text-scramble').forEach(el => {
          el.dispatchEvent(new Event('scramble:trigger'));
        });
      }
    }, 100);
  }, { passive: true });

  // Nav indicator tracking
  function updateNavIndicator(progress: number) {
    const navContainer = document.getElementById('nav-links');
    const indicator = document.getElementById('nav-indicator');
    const links = navContainer?.querySelectorAll<HTMLAnchorElement>('.nav-link');
    if (!navContainer || !indicator || !links || links.length === 0) return;

    const fromIndex = Math.max(0, Math.min(Math.floor(progress), links.length - 1));
    const toIndex = Math.min(fromIndex + 1, links.length - 1);
    const fraction = progress - fromIndex;

    const containerRect = navContainer.getBoundingClientRect();
    const fromRect = links[fromIndex].getBoundingClientRect();
    const toRect = links[toIndex].getBoundingClientRect();

    const fromX = fromRect.left - containerRect.left;
    const toX = toRect.left - containerRect.left;
    const x = fromX + (toX - fromX) * fraction;
    const width = fromRect.width + (toRect.width - fromRect.width) * fraction;

    indicator.style.transition = 'none';
    indicator.style.width = `${width}px`;
    indicator.style.transform = `translateX(${x}px)`;
    indicator.style.opacity = '1';
  }

  // Handle nav click -> scroll to panel
  const isDesktop = () => window.matchMedia('(min-width: 768px)').matches;

  function navigateToPanel(index: number) {
    container.scrollTo({
      left: index * container.clientWidth,
      behavior: isDesktop() ? 'instant' : 'smooth',
    });

    // On desktop, scrollTo with instant + overflow hidden may not fire scroll event
    // so manually handle URL + animation re-trigger
    if (isDesktop()) {
      const newPath = pages[index];
      if (newPath && location.pathname !== newPath) {
        history.replaceState(null, '', newPath);
      }
      updateNavIndicator(index);
      if (index !== lastActiveIndex) {
        lastActiveIndex = index;
        const panels = container.querySelectorAll('.swipe-panel');
        panels[index]?.querySelectorAll('.text-scramble').forEach(el => {
          el.dispatchEvent(new Event('scramble:trigger'));
        });
      }
    }
  }

  document.querySelectorAll<HTMLAnchorElement>('.nav-link').forEach((link, i) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      navigateToPanel(i);
    });
  });

  // Position indicator on load after fonts
  document.fonts?.ready.then(() => {
    const path = location.pathname;
    const index = pages.findIndex(p =>
      p === '/' ? path === '/' || path === '' : path.startsWith(p)
    );
    updateNavIndicator(Math.max(0, index));
  });

  // Live status footer
  const statusDot = document.getElementById('status-dot')!;
  const statusText = document.getElementById('status-text')!;

  const STATUS_COLORS: Record<string, string> = {
    green: '#22c55e',
    yellow: '#eab308',
    red: '#ef4444',
    offline: '#6b7280',
  };

  async function updateStatus() {
    try {
      const res = await fetch('/api/status');
      const data = await res.json();

      if (data.status === 'offline') {
        statusDot.style.background = STATUS_COLORS.offline;
        statusText.textContent = 'optiplex offline';
        return;
      }

      statusDot.style.background = STATUS_COLORS[data.overall] ?? STATUS_COLORS.green;

      const parts: string[] = ['optiplex'];

      // Services
      if (data.services.running === data.services.total) {
        parts.push(`${data.services.total} services`);
      } else {
        parts.push(`${data.services.running}/${data.services.total} services`);
      }

      // Crons
      if (data.crons.error > 0) {
        parts.push(`${data.crons.error} cron err`);
      } else if (data.crons.ok === data.crons.total) {
        parts.push(`${data.crons.total} crons ok`);
      } else {
        parts.push(`${data.crons.ok}/${data.crons.total} crons`);
      }

      // System vitals
      if (data.cpu !== null) parts.push(`cpu ${data.cpu}%`);
      if (data.memory !== null) parts.push(`mem ${data.memory}%`);
      if (data.uptime) parts.push(data.uptime);

      statusText.textContent = parts.join(' · ');
    } catch {
      statusDot.style.background = STATUS_COLORS.offline;
      statusText.textContent = 'status unavailable';
    }
  }

  updateStatus();
  setInterval(updateStatus, 30000);

  // Currently building
  const buildingRepos = document.getElementById('building-repos');
  const buildingSection = document.getElementById('building-section');

  function timeAgo(dateStr: string): string {
    const diff = Date.now() - new Date(dateStr).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return 'just now';
    if (mins < 60) return `${mins}m ago`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return `${hrs}h ago`;
    const days = Math.floor(hrs / 24);
    return `${days}d ago`;
  }

  if (buildingRepos) {
    fetch('/api/activity')
      .then(r => r.json())
      .then((data: { repos: Array<{ name: string; url: string; description: string; lastCommit: string; pushedAt: string }> }) => {
        if (data.repos.length === 0) {
          buildingSection?.remove();
          return;
        }
        data.repos.forEach((repo, i) => {
          const row = document.createElement('a');
          row.href = repo.url;
          row.target = '_blank';
          row.rel = 'noopener';
          row.className = 'building-row';
          row.style.animationDelay = `${i * 120}ms`;

          const dot = document.createElement('span');
          dot.className = 'building-dot';

          const info = document.createElement('span');
          info.className = 'building-info';

          const name = document.createElement('span');
          name.className = 'building-name';
          name.textContent = repo.name;

          const commit = document.createElement('span');
          commit.className = 'building-commit';
          commit.textContent = repo.lastCommit || repo.description || '';

          info.appendChild(name);
          if (commit.textContent) info.appendChild(commit);

          const time = document.createElement('span');
          time.className = 'building-time';
          time.textContent = repo.pushedAt ? timeAgo(repo.pushedAt) : '';

          row.appendChild(dot);
          row.appendChild(info);
          row.appendChild(time);
          buildingRepos.appendChild(row);
        });
      })
      .catch(() => buildingSection?.remove());
  }
</script>

<style>
  body {
    overflow: hidden;
    height: 100dvh;
  }

  .swipe-container {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    height: calc(100dvh - 57px - 37px);
    scrollbar-width: none;
  }

  .swipe-container::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 768px) {
    .swipe-container {
      overflow-x: hidden;
      scroll-snap-type: none;
    }
  }

  .swipe-panel {
    min-width: 100%;
    scroll-snap-align: start;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
    position: relative;
  }

  .panel-content {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  /* Home */
  .hero {
    padding: 4rem 0 3rem;
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: 3.5rem;
    font-weight: 700;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.75rem;
  }

  .bio {
    margin-top: 0.25rem;
  }

  .bio-role {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .bio-role a {
    color: var(--purple);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .bio-role a:hover {
    opacity: 0.7;
  }

  .bio-tagline {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.3);
    margin-top: 0.25rem;
  }

  .bio-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .bio-links a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    transition: color 0.2s;
  }

  .bio-links a:hover {
    color: var(--purple);
  }

  .building-section {
    margin-bottom: 2rem;
    position: relative;
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.04), rgba(249, 115, 22, 0.02));
    border: 1px solid var(--border);
    border-left: 2px solid var(--purple);
    border-radius: 8px;
    overflow: hidden;
  }

  .building-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, var(--purple), transparent 60%);
    opacity: 0.5;
  }

  .building-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem 0;
  }

  .building-pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--purple);
    box-shadow: 0 0 6px var(--purple), 0 0 12px rgba(168, 85, 247, 0.3);
    animation: building-glow 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes building-glow {
    0%, 100% { opacity: 1; box-shadow: 0 0 6px var(--purple), 0 0 12px rgba(168, 85, 247, 0.3); }
    50% { opacity: 0.5; box-shadow: 0 0 3px var(--purple), 0 0 6px rgba(168, 85, 247, 0.15); }
  }

  .building-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.35);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .building-repos {
    display: flex;
    flex-direction: column;
    padding: 0.5rem 0;
  }

  :global(.building-row) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1.25rem;
    text-decoration: none;
    transition: background 0.15s;
    animation: building-fade-in 0.4s ease-out both;
  }

  :global(.building-row:hover) {
    background: rgba(168, 85, 247, 0.06);
  }

  @keyframes building-fade-in {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }

  :global(.building-dot) {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #a855f7;
    opacity: 0.6;
    flex-shrink: 0;
  }

  :global(.building-row:hover .building-dot) {
    opacity: 1;
    box-shadow: 0 0 6px rgba(168, 85, 247, 0.5);
  }

  :global(.building-info) {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    flex: 1;
    min-width: 0;
  }

  :global(.building-name) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 500;
    color: #a855f7;
  }

  :global(.building-commit) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.25);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.building-time) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
    white-space: nowrap;
  }

  :global(.building-row:hover .building-time) {
    color: rgba(255, 255, 255, 0.4);
  }

  .hero-sub {
    font-size: 1.125rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .global-footer {
    padding: 0.6rem 1.5rem;
    border-top: 1px solid var(--border);
    background: rgba(10, 10, 11, 0.8);
    backdrop-filter: blur(12px);
  }

  .status-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6b7280;
    flex-shrink: 0;
    animation: pulse 2s ease-in-out infinite;
  }

  .status-text {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: lowercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Projects */
  .page-header {
    padding: 2rem 0 2.5rem;
  }

  .page-title {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .page-desc {
    color: var(--text-muted);
  }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .project-card {
    display: block;
    padding: 1.25rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: background 0.2s, border-color 0.2s;
  }

  .project-card:hover {
    background: var(--bg-hover);
    border-color: var(--purple);
  }

  .project-name {
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .project-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .project-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    background: rgba(168, 85, 247, 0.15);
    color: var(--purple);
    border-radius: 4px;
    text-transform: lowercase;
  }

  /* About */
  .about-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
    font-size: 1.05rem;
  }
</style>
